<UserControl
    x:Class="MyJournalApp.Views.AnalyticsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:MyJournalApp.Converters"
    xmlns:viewmodels="clr-namespace:MyJournalApp.ViewModels"
    Background="#0D1117">

    <UserControl.DataContext>
        <viewmodels:AnalyticsViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVisibility" />

        <!--  Navigation Button Style  -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#8B949E" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="border"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#21262D" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Active Navigation Button  -->
        <Style
            x:Key="NavButtonActive"
            BasedOn="{StaticResource NavButton}"
            TargetType="Button">
            <Setter Property="Background" Value="#1A3A5C" />
            <Setter Property="Foreground" Value="#58A6FF" />
        </Style>

        <!--  Time Range Button  -->
        <Style x:Key="TimeRangeButton" TargetType="Button">
            <Setter Property="Background" Value="#21262D" />
            <Setter Property="Foreground" Value="#C9D1D9" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="border"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="20">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#30363D" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Active Time Range Button  -->
        <Style
            x:Key="TimeRangeButtonActive"
            BasedOn="{StaticResource TimeRangeButton}"
            TargetType="Button">
            <Setter Property="Background" Value="#238636" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <!--  Stats Card  -->
        <Style x:Key="StatsCard" TargetType="Border">
            <Setter Property="Background" Value="#161B22" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="20" />
        </Style>

        <!--  Section Card  -->
        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="Background" Value="#161B22" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="24" />
        </Style>

        <!--  Export Button  -->
        <Style x:Key="ExportButton" TargetType="Button">
            <Setter Property="Background" Value="#21262D" />
            <Setter Property="Foreground" Value="#C9D1D9" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="border"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#30363D" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  Sidebar  -->
        <Border
            Grid.Column="0"
            Background="#0D1117"
            BorderBrush="#21262D"
            BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  Logo Section  -->
                <StackPanel
                    Grid.Row="0"
                    Margin="20,24,20,32"
                    Orientation="Horizontal">
                    <Ellipse
                        Width="40"
                        Height="40"
                        Fill="#F97316" />
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock
                            FontSize="15"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Text="{Binding AppName}" />
                        <TextBlock
                            FontSize="11"
                            Foreground="#8B949E"
                            Text="{Binding AppSubtitle}" />
                    </StackPanel>
                </StackPanel>

                <!--  Navigation Menu  -->
                <StackPanel Grid.Row="1" Margin="12,0">
                    <Button
                        Command="{Binding NavigateCommand}"
                        CommandParameter="Journal"
                        Style="{StaticResource NavButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,12,0"
                                FontSize="16"
                                Text="📓" />
                            <TextBlock VerticalAlignment="Center" Text="Journal" />
                        </StackPanel>
                    </Button>

                    <Button
                        Margin="0,4,0,0"
                        Command="{Binding NavigateCommand}"
                        CommandParameter="Calendar"
                        Style="{StaticResource NavButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,12,0"
                                FontSize="16"
                                Text="📅" />
                            <TextBlock VerticalAlignment="Center" Text="Calendar" />
                        </StackPanel>
                    </Button>

                    <Button Margin="0,4,0,0" Style="{StaticResource NavButtonActive}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,12,0"
                                FontSize="16"
                                Text="📈" />
                            <TextBlock VerticalAlignment="Center" Text="Analytics" />
                        </StackPanel>
                    </Button>

                    <Button
                        Margin="0,4,0,0"
                        Command="{Binding NavigateCommand}"
                        CommandParameter="Settings"
                        Style="{StaticResource NavButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,12,0"
                                FontSize="16"
                                Text="⚙️" />
                            <TextBlock VerticalAlignment="Center" Text="Settings" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!--  Logout Button  -->
                <Button
                    Grid.Row="2"
                    Margin="12,0,12,20"
                    Command="{Binding LogoutCommand}"
                    Style="{StaticResource NavButton}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock
                            Margin="0,0,12,0"
                            FontSize="16"
                            Text="🚪" />
                        <TextBlock VerticalAlignment="Center" Text="Log Out" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!--  Main Content  -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="32,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  Header  -->
                <Grid Grid.Row="0" Margin="0,0,0,24">
                    <StackPanel>
                        <TextBlock
                            FontSize="28"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="Your Insights" />
                        <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                            <TextBlock
                                FontSize="14"
                                Foreground="#8B949E"
                                Text="Overview for " />
                            <TextBlock
                                FontSize="14"
                                Foreground="#22C55E"
                                Text="{Binding OverviewPeriod}" />
                        </StackPanel>
                    </StackPanel>

                    <Button
                        HorizontalAlignment="Right"
                        Command="{Binding ExportDataCommand}"
                        Style="{StaticResource ExportButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,8,0"
                                FontSize="12"
                                Text="⬇️" />
                            <TextBlock Text="Export Data" />
                        </StackPanel>
                    </Button>
                </Grid>

                <!--  Time Range Buttons  -->
                <StackPanel
                    Grid.Row="1"
                    Margin="0,0,0,24"
                    Orientation="Horizontal">
                    <Button Command="{Binding SelectTimeRangeCommand}" CommandParameter="Last 7 Days">
                        <Button.Style>
                            <Style BasedOn="{StaticResource TimeRangeButton}" TargetType="Button">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLast7Days}" Value="True">
                                        <Setter Property="Background" Value="#238636" />
                                        <Setter Property="Foreground" Value="White" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Margin="0,0,6,0" Text="⏱️" />
                            <TextBlock Text="Last 7 Days" />
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding SelectTimeRangeCommand}" CommandParameter="This Month">
                        <Button.Style>
                            <Style BasedOn="{StaticResource TimeRangeButton}" TargetType="Button">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsThisMonth}" Value="True">
                                        <Setter Property="Background" Value="#238636" />
                                        <Setter Property="Foreground" Value="White" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Margin="0,0,6,0" Text="📅" />
                            <TextBlock Text="This Month" />
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding SelectTimeRangeCommand}" CommandParameter="Custom Range">
                        <Button.Style>
                            <Style BasedOn="{StaticResource TimeRangeButton}" TargetType="Button">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCustomRange}" Value="True">
                                        <Setter Property="Background" Value="#238636" />
                                        <Setter Property="Foreground" Value="White" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Margin="0,0,6,0" Text="📅" />
                            <TextBlock Text="Custom Range" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!--  Stats Cards Row  -->
                <Grid Grid.Row="2" Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!--  Total Entries Card  -->
                    <Border Grid.Column="0" Style="{StaticResource StatsCard}">
                        <Grid>
                            <StackPanel>
                                <Border
                                    Width="40"
                                    Height="40"
                                    Margin="0,0,0,12"
                                    HorizontalAlignment="Left"
                                    Background="#1A3A5C"
                                    CornerRadius="10">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="18"
                                        Text="📊" />
                                </Border>
                                <TextBlock
                                    Margin="0,0,0,4"
                                    FontSize="13"
                                    Foreground="#8B949E"
                                    Text="Total Entries" />
                                <TextBlock
                                    FontSize="32"
                                    FontWeight="Bold"
                                    Foreground="White"
                                    Text="{Binding TotalEntries}" />
                            </StackPanel>
                            <TextBlock
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                FontSize="12"
                                FontWeight="SemiBold"
                                Foreground="#22C55E"
                                Text="{Binding EntriesChange}" />
                        </Grid>
                    </Border>

                    <!--  Avg Mood Score Card  -->
                    <Border Grid.Column="2" Style="{StaticResource StatsCard}">
                        <Grid>
                            <StackPanel>
                                <Border
                                    Width="40"
                                    Height="40"
                                    Margin="0,0,0,12"
                                    HorizontalAlignment="Left"
                                    Background="#2D2A1A"
                                    CornerRadius="10">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="18"
                                        Text="😊" />
                                </Border>
                                <TextBlock
                                    Margin="0,0,0,4"
                                    FontSize="13"
                                    Foreground="#8B949E"
                                    Text="Avg. Mood Score" />
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock
                                        FontSize="32"
                                        FontWeight="Bold"
                                        Foreground="White"
                                        Text="{Binding AvgMoodScore}" />
                                    <TextBlock
                                        Margin="2,0,0,6"
                                        VerticalAlignment="Bottom"
                                        FontSize="18"
                                        Foreground="#8B949E"
                                        Text="/10" />
                                </StackPanel>
                            </StackPanel>
                            <TextBlock
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                FontSize="12"
                                FontWeight="SemiBold"
                                Foreground="#22C55E"
                                Text="{Binding MoodScoreChange}" />
                        </Grid>
                    </Border>

                    <!--  Total Word Count Card  -->
                    <Border Grid.Column="4" Style="{StaticResource StatsCard}">
                        <Grid>
                            <StackPanel>
                                <Border
                                    Width="40"
                                    Height="40"
                                    Margin="0,0,0,12"
                                    HorizontalAlignment="Left"
                                    Background="#251F2D"
                                    CornerRadius="10">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="18"
                                        Text="💬" />
                                </Border>
                                <TextBlock
                                    Margin="0,0,0,4"
                                    FontSize="13"
                                    Foreground="#8B949E"
                                    Text="Total Word Count" />
                                <TextBlock
                                    FontSize="32"
                                    FontWeight="Bold"
                                    Foreground="White"
                                    Text="{Binding TotalWordCount, StringFormat={}{0:N0}}" />
                            </StackPanel>
                            <TextBlock
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                FontSize="12"
                                FontWeight="SemiBold"
                                Foreground="#22C55E"
                                Text="{Binding WordCountChange}" />
                        </Grid>
                    </Border>
                </Grid>

                <!--  Mood Charts Row  -->
                <Grid Grid.Row="3" Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!--  Mood Fluctuations Chart  -->
                    <Border Grid.Column="0" Style="{StaticResource SectionCard}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!--  Header  -->
                            <Grid Grid.Row="0" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock
                                        FontSize="16"
                                        FontWeight="SemiBold"
                                        Foreground="White"
                                        Text="Mood Fluctuations" />
                                    <TextBlock
                                        Margin="0,4,0,0"
                                        FontSize="12"
                                        Foreground="#8B949E"
                                        Text="{Binding MoodTrend}" />
                                </StackPanel>
                                <StackPanel HorizontalAlignment="Right">
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        FontSize="18"
                                        FontWeight="Bold"
                                        Foreground="White"
                                        Text="{Binding TopMood}" />
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        FontSize="11"
                                        Foreground="#22C55E"
                                        Text="Top Mood" />
                                </StackPanel>
                            </Grid>

                            <!--  Chart Area (Simplified line representation)  -->
                            <Border
                                Grid.Row="1"
                                Height="120"
                                Margin="0,16">
                                <Canvas>
                                    <!--  Simple line chart visualization  -->
                                    <Polyline
                                        Fill="Transparent"
                                        Points="0,80 30,70 60,75 90,60 120,50 150,55 180,40 210,45 240,35 270,30 300,25 330,20"
                                        Stroke="#58A6FF"
                                        StrokeThickness="2" />
                                    <!--  Area fill  -->
                                    <Polygon
                                        Fill="#1A3A5C"
                                        Opacity="0.3"
                                        Points="0,80 30,70 60,75 90,60 120,50 150,55 180,40 210,45 240,35 270,30 300,25 330,20 330,100 0,100" />
                                </Canvas>
                            </Border>

                            <!--  Week Labels  -->
                            <UniformGrid Grid.Row="2" Columns="4">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="10"
                                    Foreground="#8B949E"
                                    Text="WEEK 1" />
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="10"
                                    Foreground="#8B949E"
                                    Text="WEEK 2" />
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="10"
                                    Foreground="#8B949E"
                                    Text="WEEK 3" />
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="10"
                                    Foreground="#8B949E"
                                    Text="WEEK 4" />
                            </UniformGrid>
                        </Grid>
                    </Border>

                    <!--  Mood Breakdown Donut Chart  -->
                    <Border Grid.Column="2" Style="{StaticResource SectionCard}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                                <TextBlock
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Foreground="White"
                                    Text="Mood Breakdown" />
                                <TextBlock
                                    Margin="0,4,0,0"
                                    FontSize="12"
                                    Foreground="#8B949E"
                                    Text="Distribution of your daily logs." />
                            </StackPanel>

                            <!--  Donut Chart Representation  -->
                            <Grid
                                Grid.Row="1"
                                Width="120"
                                Height="120"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                                <!--  Outer ring segments  -->
                                <Ellipse
                                    Width="120"
                                    Height="120"
                                    Stroke="#58A6FF"
                                    StrokeDashArray="2.83,1.47,1.88,10"
                                    StrokeDashOffset="-0.4"
                                    StrokeThickness="16" />
                                <!--  Inner circle  -->
                                <Ellipse
                                    Width="72"
                                    Height="72"
                                    Fill="#161B22" />
                                <!--  Center text  -->
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontSize="24"
                                        FontWeight="Bold"
                                        Foreground="White"
                                        Text="{Binding TotalEntries}" />
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontSize="10"
                                        Foreground="#8B949E"
                                        Text="LOGS" />
                                </StackPanel>
                            </Grid>

                            <!--  Legend  -->
                            <ItemsControl
                                Grid.Row="2"
                                Margin="0,16,0,0"
                                ItemsSource="{Binding MoodBreakdown}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,4">
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse
                                                    Width="10"
                                                    Height="10"
                                                    Margin="0,0,8,0">
                                                    <Ellipse.Fill>
                                                        <SolidColorBrush Color="{Binding Color}" />
                                                    </Ellipse.Fill>
                                                </Ellipse>
                                                <TextBlock
                                                    FontSize="12"
                                                    Foreground="#C9D1D9"
                                                    Text="{Binding Mood}" />
                                            </StackPanel>
                                            <TextBlock
                                                HorizontalAlignment="Right"
                                                FontSize="12"
                                                FontWeight="SemiBold"
                                                Foreground="White"
                                                Text="{Binding Percentage, StringFormat={}{0}%}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>
                </Grid>

                <!--  Bottom Row: Tags and Writing Consistency  -->
                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!--  Top Context Tags  -->
                    <Border Grid.Column="0" Style="{StaticResource SectionCard}">
                        <StackPanel>
                            <TextBlock
                                FontSize="16"
                                FontWeight="SemiBold"
                                Foreground="White"
                                Text="Top Context Tags" />
                            <TextBlock
                                Margin="0,4,0,20"
                                FontSize="12"
                                Foreground="#8B949E"
                                Text="What you write about most." />

                            <ItemsControl ItemsSource="{Binding TopContextTags}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0,0,16">
                                            <Grid>
                                                <TextBlock
                                                    FontSize="13"
                                                    FontWeight="SemiBold"
                                                    Foreground="White"
                                                    Text="{Binding Tag}" />
                                                <TextBlock
                                                    HorizontalAlignment="Right"
                                                    FontSize="12"
                                                    Foreground="#8B949E"
                                                    Text="{Binding EntryCount, StringFormat={}{0} entries}" />
                                            </Grid>
                                            <Border
                                                Height="6"
                                                Margin="0,8,0,0"
                                                Background="#21262D"
                                                CornerRadius="3">
                                                <Border
                                                    Width="{Binding BarWidth}"
                                                    HorizontalAlignment="Left"
                                                    CornerRadius="3">
                                                    <Border.Background>
                                                        <SolidColorBrush Color="{Binding Color}" />
                                                    </Border.Background>
                                                </Border>
                                            </Border>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!--  Writing Consistency  -->
                    <Border Grid.Column="2" Style="{StaticResource SectionCard}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,20">
                                <StackPanel>
                                    <TextBlock
                                        FontSize="16"
                                        FontWeight="SemiBold"
                                        Foreground="White"
                                        Text="Writing Consistency" />
                                    <TextBlock
                                        Margin="0,4,0,0"
                                        FontSize="12"
                                        Foreground="#8B949E"
                                        Text="Words written this week." />
                                </StackPanel>
                                <Border
                                    Padding="12,6"
                                    HorizontalAlignment="Right"
                                    Background="#22C55E"
                                    CornerRadius="12">
                                    <TextBlock
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        Foreground="White"
                                        Text="{Binding DailyAvgWords, StringFormat=Daily Avg: {0:N0}}" />
                                </Border>
                            </Grid>

                            <!--  Bar Chart  -->
                            <ItemsControl Grid.Row="1" ItemsSource="{Binding WritingConsistency}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="7" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel HorizontalAlignment="Center">
                                            <Border
                                                Width="24"
                                                Height="{Binding BarHeight}"
                                                VerticalAlignment="Bottom"
                                                CornerRadius="4,4,0,0">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                        <GradientStop Offset="0" Color="#58A6FF" />
                                                        <GradientStop Offset="1" Color="#1A3A5C" />
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                            <TextBlock
                                                Margin="0,8,0,0"
                                                HorizontalAlignment="Center"
                                                FontSize="10"
                                                Foreground="#8B949E"
                                                Text="{Binding Day}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
