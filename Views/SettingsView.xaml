<UserControl
    x:Class="MyJournalApp.Views.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:MyJournalApp.Converters"
    xmlns:viewmodels="clr-namespace:MyJournalApp.ViewModels"
    Background="{DynamicResource BackgroundPrimaryBrush}">

    <UserControl.DataContext>
        <viewmodels:SettingsViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVisibility" />

        <!--  Navigation Button Style  -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#8B949E" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="border"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#21262D" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Active Navigation Button  -->
        <Style
            x:Key="NavButtonActive"
            BasedOn="{StaticResource NavButton}"
            TargetType="Button">
            <Setter Property="Background" Value="#1A3A5C" />
            <Setter Property="Foreground" Value="#58A6FF" />
        </Style>

        <!--  Section Card  -->
        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BackgroundSecondaryBrush}" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="24" />
            <Setter Property="Margin" Value="0,0,0,20" />
        </Style>

        <!--  Input Field  -->
        <Style x:Key="InputField" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BackgroundTertiaryBrush}" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16,12" />
        </Style>

        <!--  Primary Button  -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#238636" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="20,12" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="border"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2EA043" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Toggle Switch Style  -->
        <Style x:Key="ToggleSwitch" TargetType="ToggleButton">
            <Setter Property="Width" Value="50" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <Border
                                x:Name="track"
                                Width="50"
                                Height="26"
                                Background="#30363D"
                                CornerRadius="13" />
                            <Ellipse
                                x:Name="thumb"
                                Width="20"
                                Height="20"
                                Margin="3,0,0,0"
                                HorizontalAlignment="Left"
                                Fill="White" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="track" Property="Background" Value="#58A6FF" />
                                <Setter TargetName="thumb" Property="HorizontalAlignment" Value="Right" />
                                <Setter TargetName="thumb" Property="Margin" Value="0,0,3,0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  Sidebar  -->
        <Border
            Grid.Column="0"
            Background="{DynamicResource BackgroundPrimaryBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  Logo Section  -->
                <StackPanel Grid.Row="0" Margin="20,24,20,32">
                    <TextBlock
                        FontSize="18"
                        FontWeight="Bold"
                        Foreground="White"
                        Text="My Journal" />
                    <TextBlock
                        Margin="0,4,0,0"
                        FontSize="12"
                        Foreground="#8B949E"
                        Text="Productivity &amp; Reflection" />
                </StackPanel>

                <!--  Navigation Menu  -->
                <StackPanel Grid.Row="1" Margin="12,0">
                    <Button
                        Command="{Binding NavigateCommand}"
                        CommandParameter="Entries"
                        Style="{StaticResource NavButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,12,0"
                                FontSize="16"
                                Text="📓" />
                            <TextBlock VerticalAlignment="Center" Text="Entries" />
                        </StackPanel>
                    </Button>

                    <Button
                        Margin="0,4,0,0"
                        Command="{Binding NavigateCommand}"
                        CommandParameter="Analytics"
                        Style="{StaticResource NavButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,12,0"
                                FontSize="16"
                                Text="📈" />
                            <TextBlock VerticalAlignment="Center" Text="Analytics" />
                        </StackPanel>
                    </Button>

                    <Button
                        Margin="0,4,0,0"
                        Command="{Binding NavigateCommand}"
                        CommandParameter="Calendar"
                        Style="{StaticResource NavButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,12,0"
                                FontSize="16"
                                Text="📅" />
                            <TextBlock VerticalAlignment="Center" Text="Calendar" />
                        </StackPanel>
                    </Button>

                    <Button Margin="0,4,0,0" Style="{StaticResource NavButtonActive}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,12,0"
                                FontSize="16"
                                Text="⚙️" />
                            <TextBlock VerticalAlignment="Center" Text="Settings" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!--  User Profile  -->
                <Border
                    Grid.Row="2"
                    Padding="16,16"
                    BorderBrush="#21262D"
                    BorderThickness="0,1,0,0"
                    Cursor="Hand">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Ellipse
                            Grid.Column="0"
                            Width="36"
                            Height="36"
                            Fill="#F97316" />

                        <StackPanel
                            Grid.Column="1"
                            Margin="12,0,0,0"
                            VerticalAlignment="Center">
                            <TextBlock
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="White"
                                Text="{Binding UserName}" />
                            <TextBlock
                                FontSize="11"
                                Foreground="#8B949E"
                                Text="View Profile" />
                        </StackPanel>
                    </Grid>
                    <Border.InputBindings>
                        <MouseBinding Command="{Binding ViewProfileCommand}" MouseAction="LeftClick" />
                    </Border.InputBindings>
                </Border>
            </Grid>
        </Border>

        <!--  Main Content  -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <Grid MaxWidth="700" Margin="40,24,40,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  Header  -->
                <StackPanel Grid.Row="0" Margin="0,0,0,32">
                    <TextBlock
                        FontSize="28"
                        FontWeight="Bold"
                        Foreground="White"
                        Text="Settings &amp; Preferences" />
                    <TextBlock
                        Margin="0,4,0,0"
                        FontSize="14"
                        Foreground="#8B949E"
                        Text="Manage your data, appearance, and security settings." />
                </StackPanel>

                <!--  Data Export Section  -->
                <Border Grid.Row="1" Style="{StaticResource SectionCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!--  Header  -->
                        <Grid Grid.Row="0" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    Foreground="#58A6FF"
                                    Text="Data Export" />
                                <TextBlock
                                    Margin="0,4,0,0"
                                    FontSize="13"
                                    Foreground="#8B949E"
                                    Text="Export your journal entries as a PDF for safekeeping or printing." />
                            </StackPanel>
                            <TextBlock
                                HorizontalAlignment="Right"
                                FontSize="20"
                                Text="📄" />
                        </Grid>

                        <!--  Date Pickers  -->
                        <Grid Grid.Row="1" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!--  Start Date  -->
                            <StackPanel Grid.Column="0">
                                <TextBlock
                                    Margin="0,0,0,8"
                                    FontSize="12"
                                    Foreground="#8B949E"
                                    Text="Start Date" />
                                <Border Style="{StaticResource InputField}">
                                    <Grid>
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="14"
                                            Foreground="#C9D1D9"
                                            Text="{Binding ExportStartDateFormatted}" />
                                        <TextBlock
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            FontSize="14"
                                            Foreground="#8B949E"
                                            Text="📅" />
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <!--  End Date  -->
                            <StackPanel Grid.Column="2">
                                <TextBlock
                                    Margin="0,0,0,8"
                                    FontSize="12"
                                    Foreground="#8B949E"
                                    Text="End Date" />
                                <Border Style="{StaticResource InputField}">
                                    <Grid>
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="14"
                                            Foreground="#C9D1D9"
                                            Text="{Binding ExportEndDateFormatted}" />
                                        <TextBlock
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            FontSize="14"
                                            Foreground="#8B949E"
                                            Text="📅" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <!--  Export Button  -->
                        <Button
                            Grid.Row="2"
                            HorizontalAlignment="Right"
                            Command="{Binding ExportPdfCommand}"
                            Style="{StaticResource PrimaryButton}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock
                                    Margin="0,0,8,0"
                                    FontSize="12"
                                    Text="⬇️" />
                                <TextBlock Text="Export PDF" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <!--  Appearance Section  -->
                <Border Grid.Row="2" Style="{StaticResource SectionCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!--  Header  -->
                        <Grid Grid.Row="0" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    Foreground="White"
                                    Text="Appearance" />
                                <TextBlock
                                    Margin="0,4,0,0"
                                    FontSize="13"
                                    Foreground="#8B949E"
                                    Text="Customize how the application looks on your device." />
                            </StackPanel>
                            <TextBlock
                                HorizontalAlignment="Right"
                                FontSize="20"
                                Text="🎨" />
                        </Grid>

                        <!--  Dark Mode Toggle  -->
                        <Border
                            Grid.Row="1"
                            Padding="16"
                            Background="#21262D"
                            CornerRadius="10">
                            <Grid>
                                <StackPanel Orientation="Horizontal">
                                    <Border
                                        Width="36"
                                        Height="36"
                                        Margin="0,0,16,0"
                                        Background="#30363D"
                                        CornerRadius="18">
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontSize="16"
                                            Text="🌙" />
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Foreground="White"
                                            Text="Dark Mode" />
                                        <TextBlock
                                            FontSize="12"
                                            Foreground="#8B949E"
                                            Text="Reduce eye strain" />
                                    </StackPanel>
                                </StackPanel>
                                <ToggleButton
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    IsChecked="{Binding IsDarkMode}"
                                    Style="{StaticResource ToggleSwitch}" />
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!--  Security Section  -->
                <Border Grid.Row="3" Style="{StaticResource SectionCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!--  Header  -->
                        <Grid Grid.Row="0" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    Foreground="White"
                                    Text="Security" />
                                <TextBlock
                                    Margin="0,4,0,0"
                                    FontSize="13"
                                    Foreground="#8B949E"
                                    Text="Update your password to keep your journal private." />
                            </StackPanel>
                            <TextBlock
                                HorizontalAlignment="Right"
                                FontSize="20"
                                Text="🔒" />
                        </Grid>

                        <!--  Current Password  -->
                        <StackPanel Grid.Row="1" Margin="0,0,0,16">
                            <TextBlock
                                Margin="0,0,0,8"
                                FontSize="12"
                                Foreground="#8B949E"
                                Text="Current Password" />
                            <Border Style="{StaticResource InputField}">
                                <Grid>
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="14"
                                        Foreground="#8B949E"
                                        Text="🔑" />
                                    <PasswordBox
                                        x:Name="CurrentPasswordBox"
                                        Margin="28,0,0,0"
                                        VerticalAlignment="Center"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        FontSize="14"
                                        Foreground="#C9D1D9" />
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!--  New Password Row  -->
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!--  New Password  -->
                            <StackPanel Grid.Column="0">
                                <TextBlock
                                    Margin="0,0,0,8"
                                    FontSize="12"
                                    Foreground="#8B949E"
                                    Text="New Password" />
                                <Border Style="{StaticResource InputField}">
                                    <Grid>
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="14"
                                            Foreground="#8B949E"
                                            Text="🔄" />
                                        <PasswordBox
                                            x:Name="NewPasswordBox"
                                            Margin="28,0,0,0"
                                            VerticalAlignment="Center"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            FontSize="14"
                                            Foreground="#C9D1D9" />
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <!--  Confirm Password  -->
                            <StackPanel Grid.Column="2">
                                <TextBlock
                                    Margin="0,0,0,8"
                                    FontSize="12"
                                    Foreground="#8B949E"
                                    Text="Confirm New Password" />
                                <Border Style="{StaticResource InputField}">
                                    <Grid>
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="14"
                                            Foreground="#8B949E"
                                            Text="✓" />
                                        <PasswordBox
                                            x:Name="ConfirmPasswordBox"
                                            Margin="28,0,0,0"
                                            VerticalAlignment="Center"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            FontSize="14"
                                            Foreground="#C9D1D9" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
