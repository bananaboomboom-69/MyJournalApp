<UserControl x:Class="MyJournalApp.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewmodels="clr-namespace:MyJournalApp.ViewModels"
             xmlns:converters="clr-namespace:MyJournalApp.Converters"
             Background="#0D1117">
    
    <UserControl.DataContext>
        <viewmodels:LoginViewModel />
    </UserControl.DataContext>
    
    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisibility" />
        
        <!-- Button Style -->
        <Style x:Key="AuthToggleButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="AuthToggleButtonActive" TargetType="Button" BasedOn="{StaticResource AuthToggleButton}">
            <Setter Property="Background" Value="#238636"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        
        <!-- Primary Button -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#238636"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="24,14"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="🔓" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2EA043"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1B7F2E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- TextBox Style -->
        <Style x:Key="ModernTextBox" TargetType="PasswordBox">
            <Setter Property="Background" Value="#161B22"/>
            <Setter Property="Foreground" Value="#C9D1D9"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,14"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="CaretBrush" Value="#58A6FF"/>
        </Style>
        
        <!-- Feature Card Style -->
        <Style x:Key="FeatureCard" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
    </UserControl.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header/Navigation Bar -->
        <Border Grid.Row="0" Background="#0D1117" Padding="24,16" BorderBrush="#21262D" BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <!-- Logo -->
                    <Border Width="32" Height="32" CornerRadius="6" Background="#238636" Margin="0,0,12,0">
                        <TextBlock Text="📓" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="MindJournal" FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="Help Center" Foreground="#8B949E" FontSize="13" 
                               VerticalAlignment="Center" Margin="0,0,24,0" Cursor="Hand"/>
                    <Button Content="Create Account" 
                            Background="#21262D" 
                            Foreground="White" 
                            BorderThickness="0"
                            Padding="16,8"
                            Cursor="Hand"
                            Visibility="{Binding IsNewUser, Converter={StaticResource InverseBoolToVisibility}}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="60,40">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Left Side - Decorative Image -->
            <Grid Grid.Column="0" Margin="0,0,40,0">
                <Border CornerRadius="16" Background="#161B22" ClipToBounds="True">
                    <Grid>
                        <!-- Placeholder Image with Gradient -->
                        <Border>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1A3A4A" Offset="0"/>
                                    <GradientStop Color="#0D2030" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            
                            <!-- Decorative Elements -->
                            <Grid>
                                <!-- Stone/Zen element placeholder -->
                                <Ellipse Width="200" Height="160" 
                                         Fill="#3D5A6C" 
                                         HorizontalAlignment="Center" 
                                         VerticalAlignment="Center"
                                         Margin="0,0,0,40">
                                    <Ellipse.Effect>
                                        <DropShadowEffect BlurRadius="40" ShadowDepth="10" Opacity="0.3" Color="Black"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                                
                                <!-- Pedestal -->
                                <Border Width="300" Height="20" 
                                        CornerRadius="4"
                                        HorizontalAlignment="Center" 
                                        VerticalAlignment="Center"
                                        Margin="0,140,0,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#4A6572" Offset="0"/>
                                            <GradientStop Color="#344955" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                            </Grid>
                        </Border>
                        
                        <!-- Status Badge -->
                        <Border HorizontalAlignment="Right" 
                                VerticalAlignment="Bottom" 
                                Margin="0,0,20,20"
                                Background="#161B22" 
                                CornerRadius="8"
                                Padding="16,10">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="28" Height="28" CornerRadius="6" Background="#0D419D" Margin="0,0,10,0">
                                    <TextBlock Text="🔒" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel>
                                    <TextBlock Text="STATUS" FontSize="10" Foreground="#8B949E" FontWeight="SemiBold"/>
                                    <TextBlock Text="Encrypted ✓" FontSize="12" Foreground="#58A6FF"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
            
            <!-- Right Side - Login Form -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="40,0,0,0">
                <!-- Title -->
                <TextBlock Text="Welcome back to your" FontSize="32" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="sanctuary." FontSize="32" FontWeight="Bold" Foreground="White" Margin="0,0,0,12"/>
                
                <TextBlock Text="Your thoughts are encrypted and stored locally." 
                           FontSize="14" Foreground="#8B949E" Margin="0,0,0,4"/>
                <TextBlock Text="Verify your identity to reflect." 
                           FontSize="14" Foreground="#8B949E" Margin="0,0,0,32"/>
                
                <!-- Auth Mode Toggle -->
                <Border Background="#21262D" CornerRadius="8" Padding="4" Margin="0,0,0,24" HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Password" 
                                Command="{Binding TogglePasswordModeCommand}"
                                Style="{Binding IsPasswordMode, Converter={StaticResource BoolToVisibility}, ConverterParameter=AuthToggleButtonActive}"
                                Background="{Binding IsPasswordMode, Converter={x:Null}}"
                                Foreground="{Binding IsPasswordMode, Converter={x:Null}}"
                                Padding="16,8" Margin="0" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" CornerRadius="6" Padding="16,8"
                                            Background="#21262D">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsPasswordMode}" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#238636"/>
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Content="PIN Code" 
                                Command="{Binding TogglePinModeCommand}"
                                Padding="16,8" Margin="0" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" CornerRadius="6" Padding="16,8"
                                            Background="#21262D">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsPinMode}" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#238636"/>
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Border>
                
                <!-- Username field for new users -->
                <StackPanel Visibility="{Binding IsNewUser, Converter={StaticResource BoolToVisibility}}" Margin="0,0,0,16">
                    <TextBlock Text="USERNAME" FontSize="11" FontWeight="SemiBold" Foreground="#8B949E" Margin="0,0,0,8"/>
                    <Border Background="#161B22" BorderBrush="#30363D" BorderThickness="1" CornerRadius="8">
                        <Grid>
                            <TextBlock Text="👤" FontSize="14" Foreground="#8B949E" VerticalAlignment="Center" Margin="14,0,0,0"/>
                            <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent"
                                     Foreground="#C9D1D9"
                                     BorderThickness="0"
                                     Padding="40,14,14,14"
                                     FontSize="14"
                                     CaretBrush="#58A6FF"/>
                        </Grid>
                    </Border>
                </StackPanel>
                
                <!-- Password Input -->
                <TextBlock Text="MASTER PASSWORD" FontSize="11" FontWeight="SemiBold" Foreground="#8B949E" Margin="0,0,0,8"
                           Visibility="{Binding IsPasswordMode, Converter={StaticResource BoolToVisibility}}"/>
                <TextBlock Text="PIN CODE" FontSize="11" FontWeight="SemiBold" Foreground="#8B949E" Margin="0,0,0,8"
                           Visibility="{Binding IsPinMode, Converter={StaticResource BoolToVisibility}}"/>
                
                <Border Background="#161B22" BorderBrush="#30363D" BorderThickness="1" CornerRadius="8" Margin="0,0,0,8">
                    <Grid>
                        <TextBlock Text="🔑" FontSize="14" Foreground="#8B949E" VerticalAlignment="Center" Margin="14,0,0,0"/>
                        <PasswordBox x:Name="PasswordBox"
                                     Background="Transparent"
                                     Foreground="#C9D1D9"
                                     BorderThickness="0"
                                     Padding="40,14,40,14"
                                     FontSize="14"
                                     CaretBrush="#58A6FF"
                                     PasswordChanged="PasswordBox_PasswordChanged"/>
                        <Button Content="👁" 
                                HorizontalAlignment="Right" 
                                Background="Transparent" 
                                Foreground="#8B949E"
                                BorderThickness="0"
                                Padding="14"
                                Cursor="Hand"
                                Command="{Binding ToggleShowPasswordCommand}"/>
                    </Grid>
                </Border>
                
                <!-- Error Message -->
                <Border Background="#3D1A1A" 
                        BorderBrush="#8B3232" 
                        BorderThickness="1" 
                        CornerRadius="6" 
                        Padding="12" 
                        Margin="0,0,0,16"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#F85149" FontSize="13"/>
                </Border>
                
                <!-- Login Button -->
                <Button Content="Unlock Journal" 
                        Command="{Binding LoginCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Margin="0,8,0,16"
                        Visibility="{Binding IsNewUser, Converter={StaticResource InverseBoolToVisibility}}"/>
                
                <!-- Create Account Button -->
                <Button Content="Create Account" 
                        Command="{Binding CreateAccountCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Margin="0,8,0,16"
                        Visibility="{Binding IsNewUser, Converter={StaticResource BoolToVisibility}}"/>
                
                <!-- Footer Links -->
                <Grid Margin="0,8,0,0" Visibility="{Binding IsNewUser, Converter={StaticResource InverseBoolToVisibility}}">
                    <TextBlock Text="Forgot Password?" Foreground="#8B949E" FontSize="13" HorizontalAlignment="Left" Cursor="Hand"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="🔒" FontSize="11" Foreground="#8B949E" Margin="0,0,6,0"/>
                        <TextBlock Text="End-to-end encrypted" Foreground="#8B949E" FontSize="12"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Grid>
        
        <!-- Feature Cards Section -->
        <Border Grid.Row="2" Background="#0D1117" BorderBrush="#21262D" BorderThickness="0,1,0,0" Padding="60,40">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Zero Knowledge -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,40,0">
                    <Border Width="48" Height="48" CornerRadius="12" Background="#0D419D" Margin="0,0,16,0">
                        <TextBlock Text="🔒" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Zero Knowledge" FontSize="15" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,4"/>
                        <TextBlock Text="We cannot read your entries." FontSize="12" Foreground="#8B949E"/>
                        <TextBlock Text="Your private key never leaves" FontSize="12" Foreground="#8B949E"/>
                        <TextBlock Text="your device." FontSize="12" Foreground="#8B949E"/>
                    </StackPanel>
                </StackPanel>
                
                <!-- Biometric Ready -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,40,0">
                    <Border Width="48" Height="48" CornerRadius="12" Background="#0D419D" Margin="0,0,16,0">
                        <TextBlock Text="👆" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Biometric Ready" FontSize="15" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,4"/>
                        <TextBlock Text="Compatible with FaceID and" FontSize="12" Foreground="#8B949E"/>
                        <TextBlock Text="TouchID for quick, secure" FontSize="12" Foreground="#8B949E"/>
                        <TextBlock Text="access." FontSize="12" Foreground="#8B949E"/>
                    </StackPanel>
                </StackPanel>
                
                <!-- Offline First -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Border Width="48" Height="48" CornerRadius="12" Background="#0D419D" Margin="0,0,16,0">
                        <TextBlock Text="📴" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Offline First" FontSize="15" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,4"/>
                        <TextBlock Text="No internet? No problem. Your" FontSize="12" Foreground="#8B949E"/>
                        <TextBlock Text="journal works flawlessly" FontSize="12" Foreground="#8B949E"/>
                        <TextBlock Text="offline." FontSize="12" Foreground="#8B949E"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Footer -->
        <Border Grid.Row="3" Background="#0D1117" Padding="60,20" BorderBrush="#21262D" BorderThickness="0,1,0,0">
            <StackPanel HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,12">
                    <TextBlock Text="Privacy Policy" Foreground="#8B949E" FontSize="12" Margin="0,0,24,0" Cursor="Hand"/>
                    <TextBlock Text="Terms of Service" Foreground="#8B949E" FontSize="12" Margin="0,0,24,0" Cursor="Hand"/>
                    <TextBlock Text="Contact Support" Foreground="#8B949E" FontSize="12" Cursor="Hand"/>
                </StackPanel>
                <TextBlock Text="© 2023 MindJournal. All rights reserved." 
                           Foreground="#484F58" FontSize="11" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
