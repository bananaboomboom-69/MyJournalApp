<UserControl
    x:Class="MyJournalApp.Views.TimelineView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:MyJournalApp.Converters"
    xmlns:viewmodels="clr-namespace:MyJournalApp.ViewModels"
    Background="#0D1117">

    <UserControl.DataContext>
        <viewmodels:TimelineViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVisibility" />

        <!--  Navigation Button Style  -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#8B949E" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="border"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#21262D" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Active Navigation Button  -->
        <Style
            x:Key="NavButtonActive"
            BasedOn="{StaticResource NavButton}"
            TargetType="Button">
            <Setter Property="Background" Value="#1A3A5C" />
            <Setter Property="Foreground" Value="#58A6FF" />
        </Style>

        <!--  Primary Button  -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#238636" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="border"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2EA043" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Filter Chip  -->
        <Style x:Key="FilterChip" TargetType="Border">
            <Setter Property="Background" Value="#21262D" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <!--  Tag Chip  -->
        <Style x:Key="TagChip" TargetType="Border">
            <Setter Property="Background" Value="#21262D" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Margin" Value="0,0,6,0" />
        </Style>

        <!--  Entry Card  -->
        <Style x:Key="EntryCard" TargetType="Border">
            <Setter Property="Background" Value="#161B22" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  Sidebar  -->
        <Border
            Grid.Column="0"
            Background="#0D1117"
            BorderBrush="#21262D"
            BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  Logo Section  -->
                <StackPanel Grid.Row="0" Margin="20,24,20,32">
                    <TextBlock
                        FontSize="18"
                        FontWeight="Bold"
                        Foreground="White"
                        Text="Journal App" />
                    <TextBlock
                        Margin="0,4,0,0"
                        FontSize="12"
                        Foreground="#8B949E"
                        Text="Your private space" />
                </StackPanel>

                <!--  Navigation Menu  -->
                <StackPanel Grid.Row="1" Margin="12,0">
                    <Button
                        Command="{Binding NavigateCommand}"
                        CommandParameter="Write"
                        Style="{StaticResource NavButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,12,0"
                                FontSize="16"
                                Text="✏️" />
                            <TextBlock VerticalAlignment="Center" Text="Write" />
                        </StackPanel>
                    </Button>

                    <Button
                        Margin="0,4,0,0"
                        Command="{Binding NavigateCommand}"
                        CommandParameter="Calendar"
                        Style="{StaticResource NavButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,12,0"
                                FontSize="16"
                                Text="📅" />
                            <TextBlock VerticalAlignment="Center" Text="Calendar" />
                        </StackPanel>
                    </Button>

                    <Button
                        Margin="0,4,0,0"
                        Command="{Binding NavigateCommand}"
                        CommandParameter="Timeline"
                        Style="{StaticResource NavButtonActive}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,12,0"
                                FontSize="16"
                                Text="⏱️" />
                            <TextBlock VerticalAlignment="Center" Text="Timeline" />
                        </StackPanel>
                    </Button>

                    <Button
                        Margin="0,4,0,0"
                        Command="{Binding NavigateCommand}"
                        CommandParameter="Settings"
                        Style="{StaticResource NavButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,12,0"
                                FontSize="16"
                                Text="⚙️" />
                            <TextBlock VerticalAlignment="Center" Text="Settings" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!--  User Profile  -->
                <Border
                    Grid.Row="2"
                    Padding="16,16"
                    BorderBrush="#21262D"
                    BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Ellipse
                            Grid.Column="0"
                            Width="36"
                            Height="36"
                            Fill="#F97316" />

                        <StackPanel
                            Grid.Column="1"
                            Margin="12,0,0,0"
                            VerticalAlignment="Center">
                            <TextBlock
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="White"
                                Text="{Binding UserName}" />
                            <TextBlock
                                FontSize="11"
                                Foreground="#8B949E"
                                Text="{Binding UserPlan}" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!--  Main Content  -->
        <ScrollViewer
            Grid.Column="1"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
            <Grid MaxWidth="800" Margin="40,24,40,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  Header  -->
                <Grid Grid.Row="0" Margin="0,0,0,24">
                    <StackPanel>
                        <TextBlock
                            FontSize="28"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="My Journey" />
                        <TextBlock
                            Margin="0,4,0,0"
                            FontSize="14"
                            Foreground="#8B949E"
                            Text="Reflect on your daily moments" />
                    </StackPanel>

                    <Button
                        HorizontalAlignment="Right"
                        Command="{Binding NewEntryCommand}"
                        Style="{StaticResource PrimaryButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,6,0"
                                FontSize="14"
                                FontWeight="Bold"
                                Text="+" />
                            <TextBlock Text="New Entry" />
                        </StackPanel>
                    </Button>
                </Grid>

                <!--  Search Bar  -->
                <Border
                    Grid.Row="1"
                    Margin="0,0,0,16"
                    Padding="16,12"
                    Background="#161B22"
                    BorderBrush="#30363D"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock
                            Margin="0,0,12,0"
                            VerticalAlignment="Center"
                            FontSize="16"
                            Foreground="#8B949E"
                            Text="🔍" />
                        <TextBox
                            Width="400"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0"
                            CaretBrush="#58A6FF"
                            FontSize="14"
                            Foreground="#C9D1D9"
                            Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Border>

                <!--  Filters Row  -->
                <Grid Grid.Row="2" Margin="0,0,0,24">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock
                            Margin="0,0,12,0"
                            VerticalAlignment="Center"
                            FontSize="13"
                            Foreground="#8B949E"
                            Text="Filter by:" />

                        <!--  Date Range Dropdown  -->
                        <Border Style="{StaticResource FilterChip}">
                            <ComboBox
                                Background="Transparent"
                                BorderThickness="0"
                                FontSize="12"
                                Foreground="#C9D1D9"
                                ItemsSource="{Binding DateRanges}"
                                SelectedItem="{Binding SelectedDateRange}" />
                        </Border>

                        <!--  Mood Dropdown  -->
                        <Border Style="{StaticResource FilterChip}">
                            <ComboBox
                                Background="Transparent"
                                BorderThickness="0"
                                FontSize="12"
                                Foreground="#C9D1D9"
                                ItemsSource="{Binding MoodOptions}"
                                SelectedItem="{Binding SelectedMoodFilter}" />
                        </Border>

                        <!--  Active Tag Filter  -->
                        <Border
                            Background="#1A3A5C"
                            Style="{StaticResource FilterChip}"
                            Visibility="{Binding HasTagFilter, Converter={StaticResource BoolToVisibility}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock
                                    FontSize="12"
                                    Foreground="#8B949E"
                                    Text="Tags: " />
                                <TextBlock
                                    FontSize="12"
                                    Foreground="#58A6FF"
                                    Text="{Binding SelectedTagFilter}" />
                                <Button
                                    Margin="8,0,0,0"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Command="{Binding RemoveTagFilterCommand}"
                                    Content="✕"
                                    Cursor="Hand"
                                    FontSize="10"
                                    Foreground="#8B949E" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <TextBlock
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Cursor="Hand"
                        FontSize="12"
                        Foreground="#8B949E"
                        Text="Clear all">
                        <TextBlock.InputBindings>
                            <MouseBinding Command="{Binding ClearFiltersCommand}" MouseAction="LeftClick" />
                        </TextBlock.InputBindings>
                    </TextBlock>
                </Grid>

                <!--  Entries List  -->
                <ItemsControl Grid.Row="3" ItemsSource="{Binding Entries}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!--  Date Column  -->
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        Foreground="#8B949E"
                                        Text="{Binding Month}" />
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontSize="24"
                                        FontWeight="Bold"
                                        Foreground="#C9D1D9"
                                        Text="{Binding Day}" />
                                </StackPanel>

                                <!--  Entry Card  -->
                                <Border Grid.Column="1" Style="{StaticResource EntryCard}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <!--  Title Row  -->
                                        <Grid Grid.Row="0" Margin="0,0,0,12">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock
                                                    Margin="0,0,10,0"
                                                    FontSize="18"
                                                    Text="{Binding MoodIcon}" />
                                                <TextBlock
                                                    FontSize="16"
                                                    FontWeight="SemiBold"
                                                    Foreground="White"
                                                    Text="{Binding Title}" />
                                            </StackPanel>
                                            <Button
                                                Padding="8,4"
                                                HorizontalAlignment="Right"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Content="⋯"
                                                Cursor="Hand"
                                                FontSize="16"
                                                Foreground="#8B949E" />
                                        </Grid>

                                        <!--  Content Preview  -->
                                        <TextBlock
                                            Grid.Row="1"
                                            Margin="0,0,0,12"
                                            FontSize="13"
                                            Foreground="#8B949E"
                                            Text="{Binding ContentPreview}"
                                            TextWrapping="Wrap" />

                                        <!--  Image Placeholder (if has image)  -->
                                        <Border
                                            Grid.Row="2"
                                            Height="120"
                                            Margin="0,0,0,12"
                                            CornerRadius="8"
                                            Visibility="{Binding HasImage, Converter={StaticResource BoolToVisibility}}">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Offset="0" Color="#F97316" />
                                                    <GradientStop Offset="0.5" Color="#DC2626" />
                                                    <GradientStop Offset="1" Color="#7C3AED" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>

                                        <!--  Tags  -->
                                        <ItemsControl Grid.Row="3" ItemsSource="{Binding Tags}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Style="{StaticResource TagChip}">
                                                        <TextBlock
                                                            FontSize="11"
                                                            Foreground="#8B949E"
                                                            Text="{Binding}" />
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!--  Load More Button  -->
                <Button
                    Grid.Row="4"
                    Margin="0,8,0,0"
                    Padding="16,12"
                    HorizontalAlignment="Center"
                    Background="Transparent"
                    BorderThickness="0"
                    Command="{Binding LoadMoreCommand}"
                    Content="Load older entries"
                    Cursor="Hand"
                    FontSize="13"
                    Foreground="#8B949E" />
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
