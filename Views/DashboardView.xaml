<UserControl
    x:Class="MyJournalApp.Views.DashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:MyJournalApp.Converters"
    xmlns:viewmodels="clr-namespace:MyJournalApp.ViewModels"
    Background="#0D1117">

    <UserControl.DataContext>
        <viewmodels:DashboardViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVisibility" />

        <!--  Navigation Button Style  -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#8B949E" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="border"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#21262D" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Active Navigation Button  -->
        <Style
            x:Key="NavButtonActive"
            BasedOn="{StaticResource NavButton}"
            TargetType="Button">
            <Setter Property="Background" Value="#1A3A5C" />
            <Setter Property="Foreground" Value="#58A6FF" />
        </Style>

        <!--  Card Style  -->
        <Style x:Key="DashboardCard" TargetType="Border">
            <Setter Property="Background" Value="#161B22" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="20" />
        </Style>

        <!--  Primary Button  -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#238636" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="20,12" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="border"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    Text="✏️" />
                                <ContentPresenter VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2EA043" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Tag Style  -->
        <Style x:Key="TagBorder" TargetType="Border">
            <Setter Property="Background" Value="#21262D" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0,0,8,8" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  Sidebar  -->
        <Border
            Grid.Column="0"
            Background="#0D1117"
            BorderBrush="#21262D"
            BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  Logo Section  -->
                <StackPanel
                    Grid.Row="0"
                    Margin="20,24,20,32"
                    Orientation="Horizontal">
                    <Border
                        Width="40"
                        Height="40"
                        CornerRadius="20">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Offset="0" Color="#1A3A5C" />
                                <GradientStop Offset="1" Color="#0D2030" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Ellipse
                            Width="24"
                            Height="24"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Fill="#58A6FF" />
                    </Border>
                    <TextBlock
                        Margin="12,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="Mindful Journal" />
                </StackPanel>

                <!--  Navigation Menu  -->
                <StackPanel Grid.Row="1" Margin="12,0">
                    <Button
                        Command="{Binding NavigateCommand}"
                        CommandParameter="Dashboard"
                        Style="{StaticResource NavButtonActive}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,12,0"
                                FontSize="16"
                                Text="📊" />
                            <TextBlock VerticalAlignment="Center" Text="Dashboard" />
                        </StackPanel>
                    </Button>

                    <Button
                        Margin="0,4,0,0"
                        Command="{Binding NavigateCommand}"
                        CommandParameter="Entries"
                        Style="{StaticResource NavButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,12,0"
                                FontSize="16"
                                Text="📝" />
                            <TextBlock VerticalAlignment="Center" Text="Entries" />
                        </StackPanel>
                    </Button>

                    <Button
                        Margin="0,4,0,0"
                        Command="{Binding NavigateCommand}"
                        CommandParameter="Calendar"
                        Style="{StaticResource NavButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,12,0"
                                FontSize="16"
                                Text="📅" />
                            <TextBlock VerticalAlignment="Center" Text="Calendar" />
                        </StackPanel>
                    </Button>

                    <Button
                        Margin="0,4,0,0"
                        Command="{Binding NavigateCommand}"
                        CommandParameter="Analytics"
                        Style="{StaticResource NavButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,12,0"
                                FontSize="16"
                                Text="📈" />
                            <TextBlock VerticalAlignment="Center" Text="Analytics" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!--  Settings  -->
                <Button
                    Grid.Row="2"
                    Margin="12,0,12,12"
                    Command="{Binding NavigateCommand}"
                    CommandParameter="Settings"
                    Style="{StaticResource NavButton}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock
                            Margin="0,0,12,0"
                            FontSize="16"
                            Text="⚙️" />
                        <TextBlock VerticalAlignment="Center" Text="Settings" />
                    </StackPanel>
                </Button>

                <!--  User Profile  -->
                <Border
                    Grid.Row="3"
                    Padding="16,16"
                    BorderBrush="#21262D"
                    BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Ellipse
                            Grid.Column="0"
                            Width="36"
                            Height="36"
                            Fill="#F97316" />

                        <StackPanel
                            Grid.Column="1"
                            Margin="12,0,0,0"
                            VerticalAlignment="Center">
                            <TextBlock
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="White"
                                Text="Alex M." />
                            <TextBlock
                                FontSize="11"
                                Foreground="#8B949E"
                                Text="Free Plan" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!--  Main Content  -->
        <ScrollViewer
            Grid.Column="1"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
            <Grid Margin="32,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  Header  -->
                <Grid Grid.Row="0" Margin="0,0,0,24">
                    <StackPanel>
                        <TextBlock
                            FontSize="28"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="{Binding WelcomeMessage}" />
                        <TextBlock
                            Margin="0,4,0,0"
                            FontSize="14"
                            Foreground="#8B949E"
                            Text="{Binding CurrentDate}" />
                    </StackPanel>

                    <Button
                        HorizontalAlignment="Right"
                        Command="{Binding NewEntryCommand}"
                        Content="New Entry"
                        Style="{StaticResource PrimaryButton}" />
                </Grid>

                <!--  Stats Cards Row  -->
                <Grid Grid.Row="1" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!--  Current Streak Card  -->
                    <Border Grid.Column="0" Style="{StaticResource DashboardCard}">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Offset="0" Color="#1A3A5C" />
                                <GradientStop Offset="1" Color="#0D2030" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <StackPanel>
                                <TextBlock
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    Foreground="#8B949E"
                                    Text="CURRENT STREAK" />
                                <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                                    <TextBlock
                                        FontSize="36"
                                        FontWeight="Bold"
                                        Foreground="White"
                                        Text="{Binding CurrentStreak}" />
                                    <TextBlock
                                        FontSize="36"
                                        FontWeight="Bold"
                                        Foreground="White"
                                        Text=" Days" />
                                </StackPanel>
                                <!--  Progress Bar  -->
                                <Border
                                    Height="4"
                                    Margin="0,12,0,0"
                                    Background="#21262D"
                                    CornerRadius="2">
                                    <Border
                                        Width="100"
                                        HorizontalAlignment="Left"
                                        Background="#58A6FF"
                                        CornerRadius="2" />
                                </Border>
                            </StackPanel>
                            <TextBlock
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                FontSize="24"
                                Text="🔥" />
                        </Grid>
                    </Border>

                    <!--  Longest Streak Card  -->
                    <Border Grid.Column="2" Style="{StaticResource DashboardCard}">
                        <Grid>
                            <StackPanel>
                                <TextBlock
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    Foreground="#8B949E"
                                    Text="LONGEST STREAK" />
                                <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                                    <TextBlock
                                        FontSize="36"
                                        FontWeight="Bold"
                                        Foreground="White"
                                        Text="{Binding LongestStreak}" />
                                    <TextBlock
                                        FontSize="36"
                                        FontWeight="Bold"
                                        Foreground="White"
                                        Text=" Days" />
                                </StackPanel>
                                <TextBlock
                                    Margin="0,8,0,0"
                                    FontSize="12"
                                    Foreground="#8B949E"
                                    Text="Best record achieved in March" />
                            </StackPanel>
                            <TextBlock
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                FontSize="24"
                                Text="🏆" />
                        </Grid>
                    </Border>

                    <!--  Total Entries Card  -->
                    <Border Grid.Column="4" Style="{StaticResource DashboardCard}">
                        <Grid>
                            <StackPanel>
                                <TextBlock
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    Foreground="#8B949E"
                                    Text="TOTAL ENTRIES" />
                                <TextBlock
                                    Margin="0,8,0,0"
                                    FontSize="36"
                                    FontWeight="Bold"
                                    Foreground="White"
                                    Text="{Binding TotalEntries}" />
                                <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                                    <TextBlock
                                        FontSize="12"
                                        Foreground="#22C55E"
                                        Text="+" />
                                    <TextBlock
                                        FontSize="12"
                                        Foreground="#22C55E"
                                        Text="{Binding EntriesThisWeek}" />
                                    <TextBlock
                                        FontSize="12"
                                        Foreground="#8B949E"
                                        Text=" this week" />
                                </StackPanel>
                            </StackPanel>
                            <TextBlock
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                FontSize="24"
                                Text="📋" />
                        </Grid>
                    </Border>
                </Grid>

                <!--  Charts Row  -->
                <Grid Grid.Row="2" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!--  Mood Distribution Card  -->
                    <Border Grid.Column="0" Style="{StaticResource DashboardCard}">
                        <StackPanel>
                            <Grid Margin="0,0,0,20">
                                <StackPanel>
                                    <TextBlock
                                        FontSize="16"
                                        FontWeight="SemiBold"
                                        Foreground="White"
                                        Text="Mood Distribution" />
                                    <TextBlock
                                        FontSize="12"
                                        Foreground="#8B949E"
                                        Text="Last 30 days" />
                                </StackPanel>
                                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                    <TextBlock
                                        FontSize="14"
                                        Foreground="#8B949E"
                                        Text="Most: " />
                                    <TextBlock
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Foreground="#58A6FF"
                                        Text="{Binding MostFrequentMood}" />
                                </StackPanel>
                            </Grid>

                            <!--  Mood Bars  -->
                            <ItemsControl ItemsSource="{Binding MoodDistribution}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                <TextBlock
                                                    Margin="0,0,8,0"
                                                    FontSize="16"
                                                    Text="{Binding Icon}" />
                                                <TextBlock
                                                    VerticalAlignment="Center"
                                                    FontSize="13"
                                                    Foreground="#C9D1D9"
                                                    Text="{Binding Mood}" />
                                            </StackPanel>

                                            <Border
                                                Grid.Column="1"
                                                Height="20"
                                                Background="#21262D"
                                                CornerRadius="4">
                                                <Border
                                                    Width="{Binding Percentage}"
                                                    HorizontalAlignment="Left"
                                                    Background="{Binding Color}"
                                                    CornerRadius="4" />
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!--  Writing Volume Card  -->
                    <Border Grid.Column="2" Style="{StaticResource DashboardCard}">
                        <StackPanel>
                            <Grid Margin="0,0,0,20">
                                <StackPanel>
                                    <TextBlock
                                        FontSize="16"
                                        FontWeight="SemiBold"
                                        Foreground="White"
                                        Text="Writing Volume" />
                                    <TextBlock
                                        FontSize="12"
                                        Foreground="#8B949E"
                                        Text="Last 30 days" />
                                </StackPanel>
                                <StackPanel HorizontalAlignment="Right">
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        FontSize="24"
                                        FontWeight="Bold"
                                        Foreground="White">
                                        <Run Text="{Binding TotalWordCount, StringFormat=N0}" />
                                        <Run
                                            FontSize="14"
                                            Foreground="#8B949E"
                                            Text=" words" />
                                    </TextBlock>
                                </StackPanel>
                            </Grid>

                            <!--  Simple Line Chart Placeholder  -->
                            <Canvas Height="100" Margin="0,10,0,0">
                                <Polyline
                                    Fill="Transparent"
                                    Points="0,60 50,40 100,70 150,30 200,50 250,20 300,40"
                                    Stroke="#58A6FF"
                                    StrokeThickness="2" />
                                <Polyline
                                    Points="0,60 50,40 100,70 150,30 200,50 250,20 300,40 300,100 0,100"
                                    Stroke="Transparent"
                                    StrokeThickness="0">
                                    <Polyline.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Offset="0" Color="#3358A6FF" />
                                            <GradientStop Offset="1" Color="#0058A6FF" />
                                        </LinearGradientBrush>
                                    </Polyline.Fill>
                                </Polyline>
                            </Canvas>

                            <!--  Week Labels  -->
                            <Grid Margin="0,8,0,0">
                                <TextBlock
                                    HorizontalAlignment="Left"
                                    FontSize="10"
                                    Foreground="#8B949E"
                                    Text="WEEK 1" />
                                <TextBlock
                                    Margin="-80,0,0,0"
                                    HorizontalAlignment="Center"
                                    FontSize="10"
                                    Foreground="#8B949E"
                                    Text="WEEK 2" />
                                <TextBlock
                                    Margin="80,0,0,0"
                                    HorizontalAlignment="Center"
                                    FontSize="10"
                                    Foreground="#8B949E"
                                    Text="WEEK 3" />
                                <TextBlock
                                    HorizontalAlignment="Right"
                                    FontSize="10"
                                    Foreground="#8B949E"
                                    Text="WEEK 4" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>

                <!--  Bottom Row  -->
                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="320" />
                    </Grid.ColumnDefinitions>

                    <!--  Recent Activity Card  -->
                    <Border Grid.Column="0" Style="{StaticResource DashboardCard}">
                        <StackPanel>
                            <Grid Margin="0,0,0,16">
                                <TextBlock
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Foreground="White"
                                    Text="Recent Activity" />
                                <TextBlock
                                    HorizontalAlignment="Right"
                                    Cursor="Hand"
                                    FontSize="13"
                                    Foreground="#58A6FF"
                                    Text="View All" />
                            </Grid>

                            <!--  Recent Entries List  -->
                            <ItemsControl ItemsSource="{Binding RecentEntries}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border
                                            Margin="0,0,0,8"
                                            Padding="16"
                                            Background="#0D1117"
                                            CornerRadius="8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Border
                                                    Grid.Column="0"
                                                    Width="40"
                                                    Height="40"
                                                    Margin="0,0,14,0"
                                                    Background="{Binding IconBackground}"
                                                    CornerRadius="8">
                                                    <TextBlock
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        FontSize="18"
                                                        Text="{Binding MoodIcon}" />
                                                </Border>

                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock
                                                        FontSize="14"
                                                        FontWeight="Medium"
                                                        Foreground="White"
                                                        Text="{Binding Title}" />
                                                    <TextBlock
                                                        Margin="0,2,0,0"
                                                        FontSize="12"
                                                        Foreground="#8B949E"
                                                        Text="{Binding Date}" />
                                                </StackPanel>

                                                <StackPanel
                                                    Grid.Column="2"
                                                    VerticalAlignment="Center"
                                                    Orientation="Horizontal">
                                                    <Ellipse
                                                        Width="8"
                                                        Height="8"
                                                        Margin="0,0,6,0">
                                                        <Ellipse.Fill>
                                                            <SolidColorBrush Color="{Binding MoodColor}" />
                                                        </Ellipse.Fill>
                                                    </Ellipse>
                                                    <TextBlock
                                                        FontSize="12"
                                                        Foreground="#8B949E"
                                                        Text="{Binding Mood}" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!--  Frequent Topics Card  -->
                    <Border Grid.Column="2" Style="{StaticResource DashboardCard}">
                        <StackPanel>
                            <TextBlock
                                Margin="0,0,0,16"
                                FontSize="16"
                                FontWeight="SemiBold"
                                Foreground="White"
                                Text="Frequent Topics" />

                            <!--  Tags Cloud  -->
                            <ItemsControl ItemsSource="{Binding FrequentTags}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource TagBorder}">
                                            <Border.Background>
                                                <SolidColorBrush Color="#21262D" />
                                            </Border.Background>
                                            <TextBlock FontSize="12" Text="{Binding Name}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#8B949E" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                                                <Setter Property="Foreground" Value="#58A6FF" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!--  Summary Text  -->
                            <TextBlock
                                Margin="0,16,0,0"
                                FontSize="12"
                                Foreground="#8B949E"
                                TextWrapping="Wrap">
                                <Run>You write most about</Run>
                                <Run
                                    FontWeight="SemiBold"
                                    Foreground="White"
                                    Text="Gratitude" />
                                <Run>and</Run>
                                <Run
                                    FontWeight="SemiBold"
                                    Foreground="White"
                                    Text="Work" />
                                <Run>on Tuesdays.</Run>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
