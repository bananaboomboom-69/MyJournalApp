<UserControl x:Class="MyJournalApp.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewmodels="clr-namespace:MyJournalApp.ViewModels"
             xmlns:converters="clr-namespace:MyJournalApp.Converters"
             Background="#0D1117">
    
    <UserControl.DataContext>
        <viewmodels:DashboardViewModel />
    </UserControl.DataContext>
    
    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        
        <!-- Navigation Button Style -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#21262D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Active Navigation Button -->
        <Style x:Key="NavButtonActive" TargetType="Button" BasedOn="{StaticResource NavButton}">
            <Setter Property="Background" Value="#1A3A5C"/>
            <Setter Property="Foreground" Value="#58A6FF"/>
        </Style>
        
        <!-- Card Style -->
        <Style x:Key="DashboardCard" TargetType="Border">
            <Setter Property="Background" Value="#161B22"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
        </Style>
        
        <!-- Primary Button -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#238636"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="✏️" FontSize="12" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2EA043"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Tag Style -->
        <Style x:Key="TagBorder" TargetType="Border">
            <Setter Property="Background" Value="#21262D"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
        </Style>
    </UserControl.Resources>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#0D1117" BorderBrush="#21262D" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Logo Section -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="20,24,20,32">
                    <Border Width="40" Height="40" CornerRadius="20">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#1A3A5C" Offset="0"/>
                                <GradientStop Color="#0D2030" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Ellipse Width="24" Height="24" Fill="#58A6FF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Mindful Journal" 
                               FontSize="16" 
                               FontWeight="SemiBold" 
                               Foreground="White" 
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"/>
                </StackPanel>
                
                <!-- Navigation Menu -->
                <StackPanel Grid.Row="1" Margin="12,0">
                    <Button Style="{StaticResource NavButtonActive}" 
                            Command="{Binding NavigateCommand}" 
                            CommandParameter="Dashboard">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📊" FontSize="16" Margin="0,0,12,0"/>
                            <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Style="{StaticResource NavButton}" 
                            Command="{Binding NavigateCommand}" 
                            CommandParameter="Entries"
                            Margin="0,4,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📝" FontSize="16" Margin="0,0,12,0"/>
                            <TextBlock Text="Entries" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Style="{StaticResource NavButton}" 
                            Command="{Binding NavigateCommand}" 
                            CommandParameter="Calendar"
                            Margin="0,4,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📅" FontSize="16" Margin="0,0,12,0"/>
                            <TextBlock Text="Calendar" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Style="{StaticResource NavButton}" 
                            Command="{Binding NavigateCommand}" 
                            CommandParameter="Analytics"
                            Margin="0,4,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📈" FontSize="16" Margin="0,0,12,0"/>
                            <TextBlock Text="Analytics" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                
                <!-- Settings -->
                <Button Grid.Row="2" Style="{StaticResource NavButton}" Margin="12,0,12,12">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚙️" FontSize="16" Margin="0,0,12,0"/>
                        <TextBlock Text="Settings" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                
                <!-- User Profile -->
                <Border Grid.Row="3" BorderBrush="#21262D" BorderThickness="0,1,0,0" Padding="16,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Ellipse Grid.Column="0" Width="36" Height="36" Fill="#F97316"/>
                        
                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Alex M." FontSize="13" FontWeight="SemiBold" Foreground="White"/>
                            <TextBlock Text="Free Plan" FontSize="11" Foreground="#8B949E"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
        
        <!-- Main Content -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="32,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Header -->
                <Grid Grid.Row="0" Margin="0,0,0,24">
                    <StackPanel>
                        <TextBlock Text="{Binding WelcomeMessage}" 
                                   FontSize="28" 
                                   FontWeight="Bold" 
                                   Foreground="White"/>
                        <TextBlock Text="{Binding CurrentDate}" 
                                   FontSize="14" 
                                   Foreground="#8B949E"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                    
                    <Button Content="New Entry" 
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding NewEntryCommand}"
                            HorizontalAlignment="Right"/>
                </Grid>
                
                <!-- Stats Cards Row -->
                <Grid Grid.Row="1" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Current Streak Card -->
                    <Border Grid.Column="0" Style="{StaticResource DashboardCard}">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#1A3A5C" Offset="0"/>
                                <GradientStop Color="#0D2030" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="CURRENT STREAK" FontSize="11" FontWeight="SemiBold" Foreground="#8B949E"/>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <TextBlock Text="{Binding CurrentStreak}" FontSize="36" FontWeight="Bold" Foreground="White"/>
                                    <TextBlock Text=" Days" FontSize="36" FontWeight="Bold" Foreground="White"/>
                                </StackPanel>
                                <!-- Progress Bar -->
                                <Border Height="4" Background="#21262D" CornerRadius="2" Margin="0,12,0,0">
                                    <Border Width="100" HorizontalAlignment="Left" Background="#58A6FF" CornerRadius="2"/>
                                </Border>
                            </StackPanel>
                            <TextBlock Text="🔥" FontSize="24" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>
                    
                    <!-- Longest Streak Card -->
                    <Border Grid.Column="2" Style="{StaticResource DashboardCard}">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="LONGEST STREAK" FontSize="11" FontWeight="SemiBold" Foreground="#8B949E"/>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <TextBlock Text="{Binding LongestStreak}" FontSize="36" FontWeight="Bold" Foreground="White"/>
                                    <TextBlock Text=" Days" FontSize="36" FontWeight="Bold" Foreground="White"/>
                                </StackPanel>
                                <TextBlock Text="Best record achieved in March" FontSize="12" Foreground="#8B949E" Margin="0,8,0,0"/>
                            </StackPanel>
                            <TextBlock Text="🏆" FontSize="24" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>
                    
                    <!-- Total Entries Card -->
                    <Border Grid.Column="4" Style="{StaticResource DashboardCard}">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="TOTAL ENTRIES" FontSize="11" FontWeight="SemiBold" Foreground="#8B949E"/>
                                <TextBlock Text="{Binding TotalEntries}" FontSize="36" FontWeight="Bold" Foreground="White" Margin="0,8,0,0"/>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <TextBlock Text="+" Foreground="#22C55E" FontSize="12"/>
                                    <TextBlock Text="{Binding EntriesThisWeek}" Foreground="#22C55E" FontSize="12"/>
                                    <TextBlock Text=" this week" Foreground="#8B949E" FontSize="12"/>
                                </StackPanel>
                            </StackPanel>
                            <TextBlock Text="📋" FontSize="24" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>
                </Grid>
                
                <!-- Charts Row -->
                <Grid Grid.Row="2" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Mood Distribution Card -->
                    <Border Grid.Column="0" Style="{StaticResource DashboardCard}">
                        <StackPanel>
                            <Grid Margin="0,0,0,20">
                                <StackPanel>
                                    <TextBlock Text="Mood Distribution" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                                    <TextBlock Text="Last 30 days" FontSize="12" Foreground="#8B949E"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <TextBlock Text="Most: " FontSize="14" Foreground="#8B949E"/>
                                    <TextBlock Text="{Binding MostFrequentMood}" FontSize="14" FontWeight="SemiBold" Foreground="#58A6FF"/>
                                </StackPanel>
                            </Grid>
                            
                            <!-- Mood Bars -->
                            <ItemsControl ItemsSource="{Binding MoodDistribution}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                <TextBlock Text="{Binding Icon}" FontSize="16" Margin="0,0,8,0"/>
                                                <TextBlock Text="{Binding Mood}" FontSize="13" Foreground="#C9D1D9" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            
                                            <Border Grid.Column="1" Height="20" Background="#21262D" CornerRadius="4">
                                                <Border HorizontalAlignment="Left" 
                                                        Width="{Binding Percentage}" 
                                                        Background="{Binding Color}"
                                                        CornerRadius="4"/>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                    
                    <!-- Writing Volume Card -->
                    <Border Grid.Column="2" Style="{StaticResource DashboardCard}">
                        <StackPanel>
                            <Grid Margin="0,0,0,20">
                                <StackPanel>
                                    <TextBlock Text="Writing Volume" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                                    <TextBlock Text="Last 30 days" FontSize="12" Foreground="#8B949E"/>
                                </StackPanel>
                                <StackPanel HorizontalAlignment="Right">
                                    <TextBlock FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Right">
                                        <Run Text="{Binding TotalWordCount, StringFormat=N0}"/>
                                        <Run Text=" words" FontSize="14" Foreground="#8B949E"/>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                            
                            <!-- Simple Line Chart Placeholder -->
                            <Canvas Height="100" Margin="0,10,0,0">
                                <Polyline Points="0,60 50,40 100,70 150,30 200,50 250,20 300,40" 
                                          Stroke="#58A6FF" 
                                          StrokeThickness="2"
                                          Fill="Transparent"/>
                                <Polyline Points="0,60 50,40 100,70 150,30 200,50 250,20 300,40 300,100 0,100" 
                                          Stroke="Transparent" 
                                          StrokeThickness="0">
                                    <Polyline.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#3358A6FF" Offset="0"/>
                                            <GradientStop Color="#0058A6FF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Polyline.Fill>
                                </Polyline>
                            </Canvas>
                            
                            <!-- Week Labels -->
                            <Grid Margin="0,8,0,0">
                                <TextBlock Text="WEEK 1" FontSize="10" Foreground="#8B949E" HorizontalAlignment="Left"/>
                                <TextBlock Text="WEEK 2" FontSize="10" Foreground="#8B949E" HorizontalAlignment="Center" Margin="-80,0,0,0"/>
                                <TextBlock Text="WEEK 3" FontSize="10" Foreground="#8B949E" HorizontalAlignment="Center" Margin="80,0,0,0"/>
                                <TextBlock Text="WEEK 4" FontSize="10" Foreground="#8B949E" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
                
                <!-- Bottom Row -->
                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="320"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Recent Activity Card -->
                    <Border Grid.Column="0" Style="{StaticResource DashboardCard}">
                        <StackPanel>
                            <Grid Margin="0,0,0,16">
                                <TextBlock Text="Recent Activity" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                                <TextBlock Text="View All" 
                                           FontSize="13" 
                                           Foreground="#58A6FF" 
                                           HorizontalAlignment="Right" 
                                           Cursor="Hand"/>
                            </Grid>
                            
                            <!-- Recent Entries List -->
                            <ItemsControl ItemsSource="{Binding RecentEntries}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#0D1117" CornerRadius="8" Padding="16" Margin="0,0,0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <Border Grid.Column="0" Width="40" Height="40" CornerRadius="8" 
                                                        Background="{Binding IconBackground}" Margin="0,0,14,0">
                                                    <TextBlock Text="{Binding MoodIcon}" 
                                                               FontSize="18" 
                                                               HorizontalAlignment="Center" 
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                                
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Title}" 
                                                               FontSize="14" 
                                                               FontWeight="Medium" 
                                                               Foreground="White"/>
                                                    <TextBlock Text="{Binding Date}" 
                                                               FontSize="12" 
                                                               Foreground="#8B949E"
                                                               Margin="0,2,0,0"/>
                                                </StackPanel>
                                                
                                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Ellipse Width="8" Height="8" Margin="0,0,6,0">
                                                        <Ellipse.Fill>
                                                            <SolidColorBrush Color="{Binding MoodColor}"/>
                                                        </Ellipse.Fill>
                                                    </Ellipse>
                                                    <TextBlock Text="{Binding Mood}" FontSize="12" Foreground="#8B949E"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                    
                    <!-- Frequent Topics Card -->
                    <Border Grid.Column="2" Style="{StaticResource DashboardCard}">
                        <StackPanel>
                            <TextBlock Text="Frequent Topics" FontSize="16" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,16"/>
                            
                            <!-- Tags Cloud -->
                            <ItemsControl ItemsSource="{Binding FrequentTags}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource TagBorder}">
                                            <Border.Background>
                                                <SolidColorBrush Color="#21262D"/>
                                            </Border.Background>
                                            <TextBlock Text="{Binding Name}" FontSize="12">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#8B949E"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                                                <Setter Property="Foreground" Value="#58A6FF"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            
                            <!-- Summary Text -->
                            <TextBlock FontSize="12" Foreground="#8B949E" Margin="0,16,0,0" TextWrapping="Wrap">
                                <Run>You write most about </Run>
                                <Run Text="Gratitude" FontWeight="SemiBold" Foreground="White"/>
                                <Run> and </Run>
                                <Run Text="Work" FontWeight="SemiBold" Foreground="White"/>
                                <Run> on Tuesdays.</Run>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
