<UserControl
    x:Class="MyJournalApp.Views.JournalEntryView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:MyJournalApp.Converters"
    xmlns:viewmodels="clr-namespace:MyJournalApp.ViewModels"
    Background="#0D1117">

    <UserControl.DataContext>
        <viewmodels:JournalEntryViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVisibility" />

        <!--  Navigation Button Style  -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#8B949E" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="border"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#21262D" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Active Navigation Button  -->
        <Style
            x:Key="NavButtonActive"
            BasedOn="{StaticResource NavButton}"
            TargetType="Button">
            <Setter Property="Background" Value="#1A3A5C" />
            <Setter Property="Foreground" Value="#58A6FF" />
        </Style>

        <!--  Mood Button Style  -->
        <Style x:Key="MoodButton" TargetType="Button">
            <Setter Property="Background" Value="#21262D" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="border"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="Transparent"
                            BorderThickness="2"
                            CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#30363D" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Selected Mood Button  -->
        <Style
            x:Key="MoodButtonSelected"
            BasedOn="{StaticResource MoodButton}"
            TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="border"
                            Padding="{TemplateBinding Padding}"
                            Background="#1A3A5C"
                            BorderBrush="#58A6FF"
                            BorderThickness="2"
                            CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Primary Button  -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#238636" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="20,12" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="border"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2EA043" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Delete Button  -->
        <Style x:Key="DeleteButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#F85149" />
            <Setter Property="BorderBrush" Value="#F85149" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="20,12" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="border"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3D1A1A" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Tag Chip Style  -->
        <Style x:Key="TagChip" TargetType="Border">
            <Setter Property="Background" Value="#1A3A5C" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <!--  Toolbar Button  -->
        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#8B949E" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#21262D" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="280" />
        </Grid.ColumnDefinitions>

        <!--  Left Sidebar  -->
        <Border
            Grid.Column="0"
            Background="#0D1117"
            BorderBrush="#21262D"
            BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  User Profile Section  -->
                <StackPanel
                    Grid.Row="0"
                    Margin="20,24,20,32"
                    Orientation="Horizontal">
                    <Ellipse
                        Width="40"
                        Height="40"
                        Fill="#1A3A5C" />
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Text="{Binding UserName}" />
                        <TextBlock
                            FontSize="12"
                            Foreground="#8B949E"
                            Text="{Binding UserMotto}" />
                    </StackPanel>
                </StackPanel>

                <!--  Navigation Menu  -->
                <StackPanel Grid.Row="1" Margin="12,0">
                    <Button
                        Command="{Binding NavigateCommand}"
                        CommandParameter="Journal"
                        Style="{StaticResource NavButtonActive}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,12,0"
                                FontSize="16"
                                Text="📓" />
                            <TextBlock VerticalAlignment="Center" Text="Journal" />
                        </StackPanel>
                    </Button>

                    <Button
                        Margin="0,4,0,0"
                        Command="{Binding NavigateCommand}"
                        CommandParameter="Calendar"
                        Style="{StaticResource NavButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,12,0"
                                FontSize="16"
                                Text="📅" />
                            <TextBlock VerticalAlignment="Center" Text="Calendar" />
                        </StackPanel>
                    </Button>

                    <Button
                        Margin="0,4,0,0"
                        Command="{Binding NavigateCommand}"
                        CommandParameter="Analytics"
                        Style="{StaticResource NavButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,12,0"
                                FontSize="16"
                                Text="📈" />
                            <TextBlock VerticalAlignment="Center" Text="Analytics" />
                        </StackPanel>
                    </Button>

                    <Button
                        Margin="0,4,0,0"
                        Command="{Binding NavigateCommand}"
                        CommandParameter="Settings"
                        Style="{StaticResource NavButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,12,0"
                                FontSize="16"
                                Text="⚙️" />
                            <TextBlock VerticalAlignment="Center" Text="Settings" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!--  Logout Button  -->
                <Button
                    Grid.Row="2"
                    Margin="12,0,12,20"
                    Command="{Binding LogoutCommand}"
                    Style="{StaticResource NavButton}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock
                            Margin="0,0,12,0"
                            FontSize="16"
                            Text="🚪" />
                        <TextBlock VerticalAlignment="Center" Text="Log out" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!--  Main Content Area  -->
        <Grid Grid.Column="1" Margin="32,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  Date Navigation  -->
            <Grid Grid.Row="0" Margin="0,0,0,24">
                <StackPanel Orientation="Horizontal">
                    <Button
                        Command="{Binding PreviousDayCommand}"
                        Content="◀"
                        Style="{StaticResource ToolbarButton}" />
                    <StackPanel Margin="12,0">
                        <TextBlock
                            FontSize="20"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="{Binding EntryDateFormatted}" />
                        <TextBlock
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="#58A6FF"
                            Text="{Binding TodayLabel}" />
                    </StackPanel>
                    <Button
                        Command="{Binding NextDayCommand}"
                        Content="▶"
                        Style="{StaticResource ToolbarButton}" />
                </StackPanel>

                <TextBlock
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    FontSize="12"
                    Foreground="#8B949E"
                    Text="{Binding LastSavedText}" />
            </Grid>

            <!--  Title Input  -->
            <TextBox
                Grid.Row="1"
                Padding="0,0,0,16"
                Background="Transparent"
                BorderThickness="0"
                CaretBrush="#58A6FF"
                FontSize="32"
                FontWeight="Bold"
                Foreground="White"
                Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Setter Property="Tag" Value="Reflections on Productivity" />
                    </Style>
                </TextBox.Style>
            </TextBox>

            <!--  Formatting Toolbar  -->
            <Border
                Grid.Row="2"
                Margin="0,0,0,16"
                Padding="8"
                HorizontalAlignment="Left"
                Background="#161B22"
                CornerRadius="8">
                <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource ToolbarButton}">
                        <TextBlock
                            FontSize="14"
                            FontWeight="Bold"
                            Foreground="#C9D1D9"
                            Text="B" />
                    </Button>
                    <Button Style="{StaticResource ToolbarButton}">
                        <TextBlock
                            FontSize="14"
                            FontStyle="Italic"
                            Foreground="#C9D1D9"
                            Text="I" />
                    </Button>
                    <Border
                        Width="1"
                        Margin="8,6"
                        Background="#30363D" />
                    <Button Style="{StaticResource ToolbarButton}">
                        <TextBlock
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="#C9D1D9"
                            Text="H1" />
                    </Button>
                    <Button Style="{StaticResource ToolbarButton}">
                        <TextBlock
                            FontSize="12"
                            Foreground="#C9D1D9"
                            Text="H2" />
                    </Button>
                    <Border
                        Width="1"
                        Margin="8,6"
                        Background="#30363D" />
                    <Button Style="{StaticResource ToolbarButton}">
                        <TextBlock
                            FontSize="14"
                            Foreground="#C9D1D9"
                            Text="☰" />
                    </Button>
                    <Button Style="{StaticResource ToolbarButton}">
                        <TextBlock
                            FontSize="14"
                            Foreground="#C9D1D9"
                            Text="≡" />
                    </Button>
                    <Border
                        Width="1"
                        Margin="8,6"
                        Background="#30363D" />
                    <Button Style="{StaticResource ToolbarButton}">
                        <TextBlock FontSize="14" Text="🔗" />
                    </Button>
                    <Button Style="{StaticResource ToolbarButton}">
                        <TextBlock FontSize="14" Text="🖼" />
                    </Button>
                </StackPanel>
            </Border>

            <!--  Content Area  -->
            <TextBox
                Grid.Row="3"
                Padding="0"
                AcceptsReturn="True"
                Background="Transparent"
                BorderThickness="0"
                CaretBrush="#58A6FF"
                FontSize="16"
                Foreground="#8B949E"
                Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}"
                TextWrapping="Wrap"
                VerticalScrollBarVisibility="Auto">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Setter Property="Tag" Value="Write your thoughts here... How was your day?" />
                    </Style>
                </TextBox.Style>
            </TextBox>
        </Grid>

        <!--  Right Sidebar  -->
        <Border
            Grid.Column="2"
            Background="#0D1117"
            BorderBrush="#21262D"
            BorderThickness="1,0,0,0">
            <ScrollViewer Padding="20" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!--  Save Button  -->
                    <Button
                        Margin="0,0,0,8"
                        Command="{Binding SaveEntryCommand}"
                        Style="{StaticResource PrimaryButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,8,0"
                                FontSize="12"
                                Text="💾" />
                            <TextBlock Text="{Binding SaveButtonText}" />
                        </StackPanel>
                    </Button>

                    <!--  Delete Button (only visible in edit mode)  -->
                    <Button
                        Margin="0,0,0,32"
                        Command="{Binding DeleteEntryCommand}"
                        Style="{StaticResource DeleteButton}"
                        Visibility="{Binding DeleteButtonVisible, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,8,0"
                                FontSize="12"
                                Text="🗑" />
                            <TextBlock Text="Delete" />
                        </StackPanel>
                    </Button>

                    <!--  Primary Mood Section  -->
                    <TextBlock
                        Margin="0,0,0,12"
                        FontSize="11"
                        FontWeight="SemiBold"
                        Foreground="#8B949E"
                        Text="PRIMARY MOOD (Required)" />

                    <!--  Positive Moods  -->
                    <TextBlock
                        Margin="0,0,0,8"
                        FontSize="12"
                        Foreground="#8B949E"
                        Text="Positive" />
                    <StackPanel Margin="0,0,0,16" Orientation="Horizontal">
                        <Button
                            Command="{Binding SelectPrimaryMoodCommand}"
                            CommandParameter="Happy"
                            Style="{StaticResource MoodButton}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border
                                        x:Name="border"
                                        Padding="12,8"
                                        Background="#21262D"
                                        BorderBrush="Transparent"
                                        BorderThickness="2"
                                        CornerRadius="12">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                FontSize="20"
                                                Text="😊" />
                                            <TextBlock
                                                Margin="0,4,0,0"
                                                HorizontalAlignment="Center"
                                                FontSize="10"
                                                Foreground="#8B949E"
                                                Text="Happy" />
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsHappySelected}" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#1A3A5C" />
                                            <Setter TargetName="border" Property="BorderBrush" Value="#58A6FF" />
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button
                            Command="{Binding SelectPrimaryMoodCommand}"
                            CommandParameter="Calm"
                            Style="{StaticResource MoodButton}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border
                                        x:Name="border"
                                        Padding="12,8"
                                        Background="#21262D"
                                        BorderBrush="Transparent"
                                        BorderThickness="2"
                                        CornerRadius="12">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                FontSize="20"
                                                Text="😌" />
                                            <TextBlock
                                                Margin="0,4,0,0"
                                                HorizontalAlignment="Center"
                                                FontSize="10"
                                                Foreground="#8B949E"
                                                Text="Calm" />
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsCalmSelected}" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#1A3A5C" />
                                            <Setter TargetName="border" Property="BorderBrush" Value="#58A6FF" />
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button
                            Command="{Binding SelectPrimaryMoodCommand}"
                            CommandParameter="Productive"
                            Style="{StaticResource MoodButton}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border
                                        x:Name="border"
                                        Padding="12,8"
                                        Background="#21262D"
                                        BorderBrush="Transparent"
                                        BorderThickness="2"
                                        CornerRadius="12">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                FontSize="20"
                                                Text="⚡" />
                                            <TextBlock
                                                Margin="0,4,0,0"
                                                HorizontalAlignment="Center"
                                                FontSize="10"
                                                Foreground="#8B949E"
                                                Text="Focused" />
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsProductiveSelected}" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#1A3A5C" />
                                            <Setter TargetName="border" Property="BorderBrush" Value="#58A6FF" />
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>

                    <!--  Challenging Moods  -->
                    <TextBlock
                        Margin="0,0,0,8"
                        FontSize="12"
                        Foreground="#8B949E"
                        Text="Challenging" />
                    <StackPanel Margin="0,0,0,24" Orientation="Horizontal">
                        <Button
                            Command="{Binding SelectPrimaryMoodCommand}"
                            CommandParameter="Anxious"
                            Style="{StaticResource MoodButton}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border
                                        x:Name="border"
                                        Padding="12,8"
                                        Background="#21262D"
                                        BorderBrush="Transparent"
                                        BorderThickness="2"
                                        CornerRadius="12">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                FontSize="20"
                                                Text="😰" />
                                            <TextBlock
                                                Margin="0,4,0,0"
                                                HorizontalAlignment="Center"
                                                FontSize="10"
                                                Foreground="#8B949E"
                                                Text="Anxious" />
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsAnxiousSelected}" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#1A3A5C" />
                                            <Setter TargetName="border" Property="BorderBrush" Value="#58A6FF" />
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button
                            Command="{Binding SelectPrimaryMoodCommand}"
                            CommandParameter="Sad"
                            Style="{StaticResource MoodButton}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border
                                        x:Name="border"
                                        Padding="12,8"
                                        Background="#21262D"
                                        BorderBrush="Transparent"
                                        BorderThickness="2"
                                        CornerRadius="12">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                FontSize="20"
                                                Text="😔" />
                                            <TextBlock
                                                Margin="0,4,0,0"
                                                HorizontalAlignment="Center"
                                                FontSize="10"
                                                Foreground="#8B949E"
                                                Text="Tired" />
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsSadSelected}" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#1A3A5C" />
                                            <Setter TargetName="border" Property="BorderBrush" Value="#58A6FF" />
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>

                    <!--  Secondary Moods Section (max 2)  -->
                    <TextBlock
                        Margin="0,16,0,12"
                        FontSize="11"
                        FontWeight="SemiBold"
                        Foreground="#8B949E"
                        Text="SECONDARY MOODS (Optional, max 2)" />
                    <WrapPanel Margin="0,0,0,24">
                        <Button
                            Command="{Binding ToggleSecondaryMoodCommand}"
                            CommandParameter="Happy"
                            Style="{StaticResource MoodButton}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border
                                        x:Name="border"
                                        Padding="8,6"
                                        Background="#21262D"
                                        BorderBrush="Transparent"
                                        BorderThickness="2"
                                        CornerRadius="12">
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            FontSize="16"
                                            Text="😊" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsHappySecondary}" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#2D4A3E" />
                                            <Setter TargetName="border" Property="BorderBrush" Value="#22C55E" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsHappySelected}" Value="True">
                                            <Setter TargetName="border" Property="Opacity" Value="0.3" />
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button
                            Command="{Binding ToggleSecondaryMoodCommand}"
                            CommandParameter="Calm"
                            Style="{StaticResource MoodButton}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border
                                        x:Name="border"
                                        Padding="8,6"
                                        Background="#21262D"
                                        BorderBrush="Transparent"
                                        BorderThickness="2"
                                        CornerRadius="12">
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            FontSize="16"
                                            Text="😌" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsCalmSecondary}" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#2D4A3E" />
                                            <Setter TargetName="border" Property="BorderBrush" Value="#22C55E" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsCalmSelected}" Value="True">
                                            <Setter TargetName="border" Property="Opacity" Value="0.3" />
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button
                            Command="{Binding ToggleSecondaryMoodCommand}"
                            CommandParameter="Productive"
                            Style="{StaticResource MoodButton}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border
                                        x:Name="border"
                                        Padding="8,6"
                                        Background="#21262D"
                                        BorderBrush="Transparent"
                                        BorderThickness="2"
                                        CornerRadius="12">
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            FontSize="16"
                                            Text="⚡" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsProductiveSecondary}" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#2D4A3E" />
                                            <Setter TargetName="border" Property="BorderBrush" Value="#22C55E" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsProductiveSelected}" Value="True">
                                            <Setter TargetName="border" Property="Opacity" Value="0.3" />
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button
                            Command="{Binding ToggleSecondaryMoodCommand}"
                            CommandParameter="Anxious"
                            Style="{StaticResource MoodButton}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border
                                        x:Name="border"
                                        Padding="8,6"
                                        Background="#21262D"
                                        BorderBrush="Transparent"
                                        BorderThickness="2"
                                        CornerRadius="12">
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            FontSize="16"
                                            Text="😰" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsAnxiousSecondary}" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#2D4A3E" />
                                            <Setter TargetName="border" Property="BorderBrush" Value="#22C55E" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsAnxiousSelected}" Value="True">
                                            <Setter TargetName="border" Property="Opacity" Value="0.3" />
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button
                            Command="{Binding ToggleSecondaryMoodCommand}"
                            CommandParameter="Sad"
                            Style="{StaticResource MoodButton}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border
                                        x:Name="border"
                                        Padding="8,6"
                                        Background="#21262D"
                                        BorderBrush="Transparent"
                                        BorderThickness="2"
                                        CornerRadius="12">
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            FontSize="16"
                                            Text="😔" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsSadSecondary}" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#2D4A3E" />
                                            <Setter TargetName="border" Property="BorderBrush" Value="#22C55E" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsSadSelected}" Value="True">
                                            <Setter TargetName="border" Property="Opacity" Value="0.3" />
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </WrapPanel>

                    <!--  Category Section  -->
                    <TextBlock
                        Margin="0,0,0,8"
                        FontSize="11"
                        FontWeight="SemiBold"
                        Foreground="#8B949E"
                        Text="CATEGORY" />
                    <ComboBox
                        Margin="0,0,0,24"
                        Padding="12,10"
                        Background="#161B22"
                        BorderBrush="#30363D"
                        Foreground="#C9D1D9"
                        ItemsSource="{Binding Categories}"
                        SelectedItem="{Binding SelectedCategory}" />

                    <!--  Tags Section  -->
                    <TextBlock
                        Margin="0,0,0,12"
                        FontSize="11"
                        FontWeight="SemiBold"
                        Foreground="#8B949E"
                        Text="TAGS" />

                    <ItemsControl ItemsSource="{Binding Tags}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource TagChip}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock
                                            FontSize="12"
                                            Foreground="#58A6FF"
                                            Text="{Binding}" />
                                        <Button
                                            Margin="6,0,0,0"
                                            Padding="0"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Command="{Binding DataContext.RemoveTagCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Content="✕"
                                            Cursor="Hand"
                                            FontSize="10"
                                            Foreground="#8B949E" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!--  Add Tag  -->
                    <Border
                        Margin="0,8,0,24"
                        Padding="10,6"
                        HorizontalAlignment="Left"
                        Background="#161B22"
                        BorderBrush="#30363D"
                        BorderThickness="1"
                        CornerRadius="14">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,6,0"
                                Foreground="#8B949E"
                                Text="+" />
                            <TextBox
                                Width="60"
                                Background="Transparent"
                                BorderThickness="0"
                                CaretBrush="#58A6FF"
                                FontSize="12"
                                Foreground="#C9D1D9"
                                Text="{Binding NewTag, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Border>

                    <!--  Weather Widget  -->
                    <Border
                        Margin="0,8,0,0"
                        Padding="16"
                        Background="#161B22"
                        CornerRadius="12">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,12,0"
                                FontSize="24"
                                Text="☁️" />
                            <StackPanel>
                                <TextBlock
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Foreground="White"
                                    Text="18° Cloudy" />
                                <TextBlock
                                    FontSize="12"
                                    Foreground="#8B949E"
                                    Text="Seattle, WA" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
