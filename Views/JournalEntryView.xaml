<UserControl x:Class="MyJournalApp.Views.JournalEntryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewmodels="clr-namespace:MyJournalApp.ViewModels"
             xmlns:converters="clr-namespace:MyJournalApp.Converters"
             Background="#0D1117">
    
    <UserControl.DataContext>
        <viewmodels:JournalEntryViewModel />
    </UserControl.DataContext>
    
    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        
        <!-- Navigation Button Style -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#21262D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Active Navigation Button -->
        <Style x:Key="NavButtonActive" TargetType="Button" BasedOn="{StaticResource NavButton}">
            <Setter Property="Background" Value="#1A3A5C"/>
            <Setter Property="Foreground" Value="#58A6FF"/>
        </Style>
        
        <!-- Mood Button Style -->
        <Style x:Key="MoodButton" TargetType="Button">
            <Setter Property="Background" Value="#21262D"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="12" 
                                Padding="{TemplateBinding Padding}"
                                BorderThickness="2"
                                BorderBrush="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#30363D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Selected Mood Button -->
        <Style x:Key="MoodButtonSelected" TargetType="Button" BasedOn="{StaticResource MoodButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="#1A3A5C" 
                                CornerRadius="12" 
                                Padding="{TemplateBinding Padding}"
                                BorderThickness="2"
                                BorderBrush="#58A6FF">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Primary Button -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#238636"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2EA043"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Delete Button -->
        <Style x:Key="DeleteButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#F85149"/>
            <Setter Property="BorderBrush" Value="#F85149"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3D1A1A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Tag Chip Style -->
        <Style x:Key="TagChip" TargetType="Border">
            <Setter Property="Background" Value="#1A3A5C"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
        
        <!-- Toolbar Button -->
        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#21262D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="280"/>
        </Grid.ColumnDefinitions>
        
        <!-- Left Sidebar -->
        <Border Grid.Column="0" Background="#0D1117" BorderBrush="#21262D" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- User Profile Section -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="20,24,20,32">
                    <Ellipse Width="40" Height="40" Fill="#1A3A5C"/>
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding UserName}" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock Text="{Binding UserMotto}" FontSize="12" Foreground="#8B949E"/>
                    </StackPanel>
                </StackPanel>
                
                <!-- Navigation Menu -->
                <StackPanel Grid.Row="1" Margin="12,0">
                    <Button Style="{StaticResource NavButtonActive}" 
                            Command="{Binding NavigateCommand}" 
                            CommandParameter="Journal">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📓" FontSize="16" Margin="0,0,12,0"/>
                            <TextBlock Text="Journal" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Style="{StaticResource NavButton}" 
                            Command="{Binding NavigateCommand}" 
                            CommandParameter="Calendar"
                            Margin="0,4,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📅" FontSize="16" Margin="0,0,12,0"/>
                            <TextBlock Text="Calendar" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Style="{StaticResource NavButton}" 
                            Command="{Binding NavigateCommand}" 
                            CommandParameter="Analytics"
                            Margin="0,4,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📈" FontSize="16" Margin="0,0,12,0"/>
                            <TextBlock Text="Analytics" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Style="{StaticResource NavButton}" 
                            Command="{Binding NavigateCommand}" 
                            CommandParameter="Settings"
                            Margin="0,4,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙️" FontSize="16" Margin="0,0,12,0"/>
                            <TextBlock Text="Settings" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                
                <!-- Logout Button -->
                <Button Grid.Row="2" Style="{StaticResource NavButton}" 
                        Command="{Binding LogoutCommand}" 
                        Margin="12,0,12,20">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🚪" FontSize="16" Margin="0,0,12,0"/>
                        <TextBlock Text="Log out" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
        
        <!-- Main Content Area -->
        <Grid Grid.Column="1" Margin="32,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Date Navigation -->
            <Grid Grid.Row="0" Margin="0,0,0,24">
                <StackPanel Orientation="Horizontal">
                    <Button Content="◀" 
                            Command="{Binding PreviousDayCommand}"
                            Style="{StaticResource ToolbarButton}"/>
                    <StackPanel Margin="12,0">
                        <TextBlock Text="{Binding EntryDateFormatted}" 
                                   FontSize="20" 
                                   FontWeight="Bold" 
                                   Foreground="White"/>
                        <TextBlock Text="{Binding TodayLabel}" 
                                   FontSize="11" 
                                   FontWeight="SemiBold"
                                   Foreground="#58A6FF"/>
                    </StackPanel>
                    <Button Content="▶" 
                            Command="{Binding NextDayCommand}"
                            Style="{StaticResource ToolbarButton}"/>
                </StackPanel>
                
                <TextBlock Text="{Binding LastSavedText}" 
                           FontSize="12" 
                           Foreground="#8B949E"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>
            </Grid>
            
            <!-- Title Input -->
            <TextBox Grid.Row="1" 
                     Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                     Background="Transparent"
                     BorderThickness="0"
                     Foreground="White"
                     FontSize="32"
                     FontWeight="Bold"
                     Padding="0,0,0,16"
                     CaretBrush="#58A6FF">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Setter Property="Tag" Value="Reflections on Productivity"/>
                    </Style>
                </TextBox.Style>
            </TextBox>
            
            <!-- Formatting Toolbar -->
            <Border Grid.Row="2" Background="#161B22" CornerRadius="8" Padding="8" Margin="0,0,0,16" HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource ToolbarButton}">
                        <TextBlock Text="B" FontWeight="Bold" FontSize="14" Foreground="#C9D1D9"/>
                    </Button>
                    <Button Style="{StaticResource ToolbarButton}">
                        <TextBlock Text="I" FontStyle="Italic" FontSize="14" Foreground="#C9D1D9"/>
                    </Button>
                    <Border Width="1" Background="#30363D" Margin="8,6"/>
                    <Button Style="{StaticResource ToolbarButton}">
                        <TextBlock Text="H1" FontSize="12" FontWeight="SemiBold" Foreground="#C9D1D9"/>
                    </Button>
                    <Button Style="{StaticResource ToolbarButton}">
                        <TextBlock Text="H2" FontSize="12" Foreground="#C9D1D9"/>
                    </Button>
                    <Border Width="1" Background="#30363D" Margin="8,6"/>
                    <Button Style="{StaticResource ToolbarButton}">
                        <TextBlock Text="☰" FontSize="14" Foreground="#C9D1D9"/>
                    </Button>
                    <Button Style="{StaticResource ToolbarButton}">
                        <TextBlock Text="≡" FontSize="14" Foreground="#C9D1D9"/>
                    </Button>
                    <Border Width="1" Background="#30363D" Margin="8,6"/>
                    <Button Style="{StaticResource ToolbarButton}">
                        <TextBlock Text="🔗" FontSize="14"/>
                    </Button>
                    <Button Style="{StaticResource ToolbarButton}">
                        <TextBlock Text="🖼" FontSize="14"/>
                    </Button>
                </StackPanel>
            </Border>
            
            <!-- Content Area -->
            <TextBox Grid.Row="3" 
                     Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}"
                     Background="Transparent"
                     BorderThickness="0"
                     Foreground="#8B949E"
                     FontSize="16"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     CaretBrush="#58A6FF"
                     Padding="0">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Setter Property="Tag" Value="Write your thoughts here... How was your day?"/>
                    </Style>
                </TextBox.Style>
            </TextBox>
        </Grid>
        
        <!-- Right Sidebar -->
        <Border Grid.Column="2" Background="#0D1117" BorderBrush="#21262D" BorderThickness="1,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                <StackPanel>
                    <!-- Save Button -->
                    <Button Command="{Binding SaveEntryCommand}" 
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💾" FontSize="12" Margin="0,0,8,0"/>
                            <TextBlock Text="Save Entry"/>
                        </StackPanel>
                    </Button>
                    
                    <!-- Delete Button -->
                    <Button Command="{Binding DeleteEntryCommand}" 
                            Style="{StaticResource DeleteButton}"
                            Margin="0,0,0,32">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🗑" FontSize="12" Margin="0,0,8,0"/>
                            <TextBlock Text="Delete"/>
                        </StackPanel>
                    </Button>
                    
                    <!-- Mood Section -->
                    <TextBlock Text="HOW ARE YOU FEELING?" 
                               FontSize="11" 
                               FontWeight="SemiBold" 
                               Foreground="#8B949E"
                               Margin="0,0,0,12"/>
                    
                    <!-- Positive Moods -->
                    <TextBlock Text="Positive" FontSize="12" Foreground="#8B949E" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Button Command="{Binding SelectMoodCommand}" CommandParameter="Happy"
                                Style="{StaticResource MoodButton}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" CornerRadius="12" Padding="12,8"
                                            Background="#21262D" BorderThickness="2" BorderBrush="Transparent">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="😊" FontSize="20" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Happy" FontSize="10" Foreground="#8B949E" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsHappySelected}" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#1A3A5C"/>
                                            <Setter TargetName="border" Property="BorderBrush" Value="#58A6FF"/>
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        
                        <Button Command="{Binding SelectMoodCommand}" CommandParameter="Calm"
                                Style="{StaticResource MoodButton}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" CornerRadius="12" Padding="12,8"
                                            Background="#21262D" BorderThickness="2" BorderBrush="Transparent">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="😌" FontSize="20" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Calm" FontSize="10" Foreground="#8B949E" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsCalmSelected}" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#1A3A5C"/>
                                            <Setter TargetName="border" Property="BorderBrush" Value="#58A6FF"/>
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        
                        <Button Command="{Binding SelectMoodCommand}" CommandParameter="Productive"
                                Style="{StaticResource MoodButton}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" CornerRadius="12" Padding="12,8"
                                            Background="#21262D" BorderThickness="2" BorderBrush="Transparent">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="⚡" FontSize="20" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Focused" FontSize="10" Foreground="#8B949E" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsProductiveSelected}" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#1A3A5C"/>
                                            <Setter TargetName="border" Property="BorderBrush" Value="#58A6FF"/>
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                    
                    <!-- Challenging Moods -->
                    <TextBlock Text="Challenging" FontSize="12" Foreground="#8B949E" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                        <Button Command="{Binding SelectMoodCommand}" CommandParameter="Anxious"
                                Style="{StaticResource MoodButton}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" CornerRadius="12" Padding="12,8"
                                            Background="#21262D" BorderThickness="2" BorderBrush="Transparent">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="😰" FontSize="20" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Anxious" FontSize="10" Foreground="#8B949E" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsAnxiousSelected}" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#1A3A5C"/>
                                            <Setter TargetName="border" Property="BorderBrush" Value="#58A6FF"/>
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        
                        <Button Command="{Binding SelectMoodCommand}" CommandParameter="Sad"
                                Style="{StaticResource MoodButton}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" CornerRadius="12" Padding="12,8"
                                            Background="#21262D" BorderThickness="2" BorderBrush="Transparent">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="😔" FontSize="20" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Tired" FontSize="10" Foreground="#8B949E" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsSadSelected}" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#1A3A5C"/>
                                            <Setter TargetName="border" Property="BorderBrush" Value="#58A6FF"/>
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                    
                    <!-- Category Section -->
                    <TextBlock Text="CATEGORY" 
                               FontSize="11" 
                               FontWeight="SemiBold" 
                               Foreground="#8B949E"
                               Margin="0,0,0,8"/>
                    <ComboBox ItemsSource="{Binding Categories}"
                              SelectedItem="{Binding SelectedCategory}"
                              Background="#161B22"
                              Foreground="#C9D1D9"
                              BorderBrush="#30363D"
                              Padding="12,10"
                              Margin="0,0,0,24"/>
                    
                    <!-- Tags Section -->
                    <TextBlock Text="TAGS" 
                               FontSize="11" 
                               FontWeight="SemiBold" 
                               Foreground="#8B949E"
                               Margin="0,0,0,12"/>
                    
                    <ItemsControl ItemsSource="{Binding Tags}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource TagChip}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding}" FontSize="12" Foreground="#58A6FF"/>
                                        <Button Content="✕" 
                                                Command="{Binding DataContext.RemoveTagCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent"
                                                Foreground="#8B949E"
                                                BorderThickness="0"
                                                FontSize="10"
                                                Margin="6,0,0,0"
                                                Cursor="Hand"
                                                Padding="0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    
                    <!-- Add Tag -->
                    <Border Background="#161B22" BorderBrush="#30363D" BorderThickness="1" CornerRadius="14" Padding="10,6" Margin="0,8,0,24" HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="+" Foreground="#8B949E" Margin="0,0,6,0"/>
                            <TextBox Text="{Binding NewTag, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="#C9D1D9"
                                     FontSize="12"
                                     Width="60"
                                     CaretBrush="#58A6FF"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Weather Widget -->
                    <Border Background="#161B22" CornerRadius="12" Padding="16" Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="☁️" FontSize="24" Margin="0,0,12,0"/>
                            <StackPanel>
                                <TextBlock Text="18° Cloudy" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                                <TextBlock Text="Seattle, WA" FontSize="12" Foreground="#8B949E"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
